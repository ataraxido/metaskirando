10\/181002\/hP8os.jpg","com":"Go !&nbsp; "},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181002\/1iC3d.jpg","com":"Glad'&nbsp; "},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181002\/AaJCG.jpg","com":"Tout bon "},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181002\/J7Vh7.jpg","com":"Vinchy nous rejoint "},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181002\/bfwMe.jpg","com":"On ne l'arrête plus "},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181002\/vrfYu.jpg","com":"Danse synchronisée "},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181002\/LEBty.jpg","com":"Excellente ici&nbsp; "},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181002\/gtnf8.jpg","com":"Au loin, la Chartreuse "},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181002\/Z0kqw.jpg","com":"Le soleil décline "},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181002\/FuxZk.jpg","com":"Fin de la bonne skiabilité "},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181002\/kWMkg.jpg","com":"On rentre "}]},{"id":"181000","titre":"Tête de la Combaz, depuis les Contamines","orientation":"SE","denivele":"1245","dif_ski":"2.3","recit":"Itinéraire suivi : classique depuis Le Baptieu en passant par l'auberge de Colombaz<br>Horaires : 3h30 A\/R<div><br><\/div><div>Première sortie, avec skis cailloux, encore nécessaire. Ça ne touche pas souvent, mais il suffit d'une fois pour détruire nos beaux skis .<\/div><div>Un dizaine de personne sur l'itinéraire ( beaucoup d'anglais, il ne doit plus y avoir de place a Cham :-)<\/div><div><br><\/div><div>Bonne trace depuis le parking d'où on chausse.<\/div><div>A partir de la cabane de berger, ça commence à souffler fort de NNE , et la neige change . Poudreuse compactée, grosses accumulations, quelques portions sous le sommet en neige béton, j'ai hésité à terminer.<\/div><div>Grosse caillante au sommet, bien 50km\/h de vent, et des nuages bien présents à mi pente .<\/div><div>Descente difficile les 200 premiers mètres, puis sous la cabane de berger, poudreuse légère, plus de vent, un régal .<\/div><div>Chemin bien enneigé, se descend facilement sans toucher si on reste attentifs, a travers champ, ça passe bien, sans trop racler le fond .&nbsp;<\/div><div><br><\/div><div>Bonne sortie avec conditions plutôt bonne pour Novembre .<\/div><div><br><\/div>","cond":"Météo\/températures : -7°c au parking<br>Conditions d'accès\/altitude du parking : ok<br>Altitude de chaussage\/déchaussage : 1200m<br>Conditions pour le ski : bonnes conditions, neige froide. 30cms au départ. 200m sommitaux grosses accumulations > 1m<br><br>Conditions nivo et activité avalancheuse : R.A.S sous 2200m, grosses accumulation sur les 200m sommitaux , neige compactée par le vent .<div><br><\/div><div><br><\/div>","skiabilite":"4","date":"1763766000","mois":"11","annee":"2025","auteur":{"id":"1049","pseudo":"piolet15"},"massif":{"id":"21","nom":"Beaufortain"},"participants":[],"sommets":[{"id":"50","sommet":"Tête de la Combaz","altitude":"2445","lat":"45.817","lng":"6.6859"}],"topos":[{"id":"439","nom":"Tête de la Combaz, depuis les Contamines"}],"depart":{"id":"221","depart":"Les Contamines (Le Baptieu)","altitude_dep":"1200","lat":"45.8139","lng":"6.7199"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181000\/e1mMX.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181000\/pPdMY.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181000\/cxIxp.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181000\/dt7YH.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181000\/mKBSY.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181000\/vH2g5.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181000\/4Y97r.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181000\/62Rey.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181000\/rIdEa.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181000\/WG5Ig.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1810\/181000\/XKmWs.jpg"}]},{"id":"180999","titre":"Pic Blanc du Galibier","orientation":"SE","denivele":"970","dif_ski":"2.2","recit":"Itinéraire suivi : départ depuis le Lautaret, on chausse au col et on suit la route du galibier (10cm de neige) jusqu’au point 2420 pour rentrer dans la combe.&nbsp;<div>Traçage de la combe puis arrivée au sommet.&nbsp;<\/div><div>Descente excellente&nbsp;<\/div><div>Entre 20cm et +1m de poudreuse en fonction de l’altitude et de la neige déposée par le vent.&nbsp;<\/div><div>Entre 2400 et 2600 gare au requin. Entre 2600 et le sommet neige poudreuse avec parfois plus d’un 1m de profondeur dues aux accumulations.<\/div><div>Belle première ❄️ de la saison&nbsp;<\/div><div><div>Horaires : 9h-14h<br><br><\/div><\/div>","cond":"Météo\/températures : - 15 au lautaret à 8h30 - glacial&nbsp;<br>Conditions d'accès\/altitude du parking : route déneigée&nbsp;<br>Altitude de chaussage\/déchaussage : 2000<br>Conditions pour le ski : excellente, entre 50 et 1m20 de poudreuse en haut&nbsp;<br><br>Conditions nivo et activité avalancheuse : RAS, pas voulu aller en nord aujourd’hui&nbsp;","skiabilite":"4","date":"1763766000","mois":"11","annee":"2025","auteur":{"id":"44039","pseudo":"lougodineau"},"massif":{"id":"13","nom":"Grandes Rousses - Arves"},"participants":[],"sommets":[{"id":"175","sommet":"Pic Blanc du Galibier","altitude":"2955","lat":"45.0641","lng":"6.3839"}],"topos":[{"id":"84","nom":"Pic Blanc du Galibier, Combe Sud-Est"}],"depart":{"id":"125","depart":"La Marionnaise (les Sestrières)","altitude_dep":"1980","lat":"45.0423","lng":"6.4177"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1809\/180999\/j3Rsj.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1809\/180999\/gxRNL.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1809\/180999\/QeuKs.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1809\/180999\/90aqF.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1809\/180999\/v34Zb.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1809\/180999\/itRL2.jpg"}]},{"id":"180998","titre":"Les Grandes Platières, Par les pistes","orientation":"N","denivele":"1150","dif_ski":"1.3","recit":"<strong>Itinéraire suivi<\/strong> : Grandes Platières depuis Flaine Forêt avec une petite descente\/montée supplémentaire&nbsp;<div><br><strong>Horaires<\/strong> : 9h45 - 14h00<br><\/div><div><br><\/div><div>Retour à Flaine pour le week-end, sans trop savoir ce que ça a posé.<\/div><div>On part à 3, avec Co et Mo, mais vu les circonstances, on ne devrait pas être seuls 😄 grand beau après une chute de neige, la moitié de la Haute Savoie doit s'être donnée rdv du côté du Grand Massif 😅<\/div><div>Et effectivement, parking des Molliets déjà bien rempli, demi-parking de Vernant rempli aussi... on trouve malgré tout une place assez facilement à Flaine Forêt!<\/div><div><br><\/div><div>Départ sous un froid mordant, accentué par les canons qui crachent fort (malgré les nouvelles chutes de neige annoncées!)<\/div><div>Les quelques passages au soleil tempèrent l'ambiance congélo... qui n'a effectivement pas rebuté grand monde malgré tout!<\/div><div>Y a du monde, mais comme souvent, on ne le sent pas tant que ça. Côté neige, j'ai quand même l'impression qu'il y en a plus qu'annoncé!<\/div><div>Au milieu, Co me dit d'aller en profiter alors je ne me fais pas prier longtemps... le fauve est lâché 😂<\/div><div>Montée aussi express que possible... je ressens un peu plus le monde dans le mur de Faust... surtout quand il faut brasser les 40cm de poudre pour dépasser 😁<\/div><div><br><\/div><div>La terrasse des Grandes Platières est bien remplie. S'ils avaient ouvert le bar et installé le mix grill, ils auraient fait une grosse journée 😂<\/div><div>Descente tout poudre mais malgré tout bien trafolée... ça remonte quand même jusqu'aux cuisses dans les portions de neige vierge restante... magnifique! Je croise les filles dans le mur, recolle sur le plat un peu plus bas et les retrouve sur le plat des Platières.<\/div><div>Casse-croûte au soleil mais à la fraîche! Puis c'est l'heure de la descente... Bon c'est pas mal mais c'est devenu sérieusement damé! On tire malgré tout notre épingle du jeu avec quelques zones de poudre qui nous donnent le sourire 😃<\/div><div>Retour à la voiture skis aux pieds... on aura bien profité du créneau... mais va falloir que ça reneige pour effacer toutes ces traces 😄<\/div><div><br><\/div>","cond":"<strong>Météo\/températures<\/strong> : Grand beau, très froid, -10°C au parking à 9h30<div><br><strong>Conditions d'accès\/altitude du parking<\/strong> : Un peu de neige sur la route \/ 1650m<\/div><div><br><strong>Altitude de chaussage \/ déchaussage<\/strong> : 1650m \/ 1650m<\/div><div><br><strong>Conditions pour le ski<\/strong> : Bonnes!<\/div><div>Ça aurait pu être fabuleux, s'il n'y avait pas eu 300 personnes 😂 mais on s'en doutait un peu en y allant! Malgré tout, c'était bon à skier même s'il fallait bien manœuvrer pour envoyer des virages dans ces 40cm de poudre profonde et légère!<\/div><div>En dessous de 2000m, plus qu'une vingtaine de cm... attention aux plaques de neige à canons qui peuvent être piègeuses<br><br><strong>Conditions nivo et activité avalancheuse<\/strong> : RAS sur cette itinéraire<br><\/div>","skiabilite":"4","date":"1763766000","mois":"11","annee":"2025","auteur":{"id":"10956","pseudo":"Arno74"},"massif":{"id":"24","nom":"Haut Giffre - Aiguilles Rouges"},"gpx":"\/sorties\/gpx\/180998.gpx","encoded":"{xxwG{yyg@NiAHoAEoAAmA?oARmATeARiALkA\\aAJmA@mAHmAJkAZcA`@{@`@}@PkABoAQiA_@aALkAZcAZaAXeATgAXeAXcARgAVgAVgANkALkAPiAPkALiAPkAJmANkAJmALkAFmAOiASiAEoAEmAAmADmAHkAHmAHmADmANiALiAr@Wj@q@FoATiA\\aA^_AXcAr@WZcAp@]RgAFmAr@St@Ip@a@f@u@p@[AoAl@g@j@m@p@^v@Ar@St@Qt@It@Dr@Vt@Cf@w@t@Mt@Oh@s@t@Nn@e@p@c@\\aAj@m@p@c@h@q@j@o@h@o@r@]r@]l@g@n@i@f@w@l@i@b@}@t@Ln@e@h@s@l@i@h@u@l@i@f@u@v@Sn@d@l@f@j@o@PkAt@It@Jh@o@n@g@l@g@j@m@b@{@NiAh@q@l@i@j@m@t@Sr@Kt@Wr@Kt@Qr@[l@k@p@a@t@[p@Zj@n@h@n@l@h@n@h@j@n@j@p@j@n@d@v@ThAUgAc@_Aq@q@k@o@k@m@o@c@m@o@q@o@k@s@s@Ks@^s@Xm@j@}@j@w@Pw@Ny@Nu@Ru@b@q@p@g@fAg@jAq@|@s@x@u@^{@Ns@`@i@p@o@j@w@@o@k@y@Du@`@k@x@g@~@i@r@k@p@y@Tw@Ts@r@g@v@