80\/H3GuK.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/iVn62.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/ldWSr.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/Kllcb.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/lacLS.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/Xu6P6.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/Wm3Mt.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/201lY.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/ljeLf.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/b3PvP.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/YYm9V.jpg","com":"&nbsp;Maman au petit Van"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/u2EGn.jpg","com":"&nbsp;Taillefer&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/g8Wjg.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/Gwf3A.jpg","com":"&nbsp;Couloir NO du petit Van"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/zzYXG.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/ZVVqb.jpg","com":"&nbsp;Combe des Vans"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/MjHNb.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/IkLOG.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/Q8tCP.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/mMCQO.jpg","com":"&nbsp;Couloir du petit Croissant"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/UX2od.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181180\/9Px4s.jpg"}]},{"id":"181179","titre":"Garten depuis Jaun","orientation":"SW","denivele":"1146","dif_ski":"2.1","recit":"Itinéraire suivi : voir topo<br>Horaires : 4h30 avec quelques aléas (bonnet envolé au sommet, peau qui se décolle pour la remontée au point 1941....)<div><br><\/div><div>Je n'étais jamais monté à ce Garten, qui me semblait trop fréquenté (ou non enneigé depuis le bas).<\/div><div>Ce jeudi me semblait idéal après les chutes de neige du début de semaine et le froid et le soleil annoncé.<\/div><div>Bingo en arrivant au parking: une belle trace de montée, mais pas encore de traces de descente.<\/div><div>Que du bonheur. Mais la différence de climat entre l'avant sommet 1941m et le vrai sommet 2040m était inattendu: en arrivant en vue du piquet sommital une bourrasque m'a arraché le bonnet! Pas question de manger le sandwich dans cette tempête. Enlevage des peaux en faisant bien attention que rien de plus ne s'envole, y compris les bâtons.<\/div><div>Poudreuse légère et beau ski.<\/div><div><br><\/div><div><br><br><\/div>","cond":"Météo\/températures : Quelques bancs nuageux au départ puis grand beau. Très fort vent au sommet.<br>Conditions d'accès\/altitude du parking : Enneigé<br>Altitude de chaussage\/déchaussage : 1021<br>Conditions pour le ski : Excellentes<br><br>Conditions nivo et activité avalancheuse : Pas de risques sur ces pentes douces.&nbsp;","skiabilite":"5","date":"1764198000","mois":"11","annee":"2025","auteur":{"id":"23544","pseudo":"le_dahu"},"massif":{"id":"29","nom":"Préalpes Fribourgeoises \/ Bernoises"},"gpx":"\/sorties\/gpx\/181179.gpx","encoded":"kyn{G}{nk@r@oATqA^cAVoA@uAEoA?qAu@U_A[]eA?oAGoA]cAw@Gg@s@w@Cu@Hw@Hw@Gi@s@i@q@KoA]aA[gAVgARqAg@w@]mAUkAHmAo@m@u@Fy@SKmAKoA]cAc@{@o@o@g@s@i@s@o@i@w@Qw@e@ImAKqAm@u@]eAWgA]eAuAiCgAkBm@iAq@gAk@m@[oA[cAoAkCsAmCm@m@c@}@a@cA]mAg@cA_@cA]mAYcAi@cAe@_Ag@cAm@u@SmAUiASmAUqA?qAa@{@WgAKoACoAEoAQmCWkDa@_FWiAo@k@s@`@_@`Ao@p@o@l@{@Io@f@YeAk@q@a@}@o@i@i@o@}AkBoA_BoA}AmA}AoA}A_APw@Go@cAMwACuAOqAw@JKkAa@_Ae@}@e@y@}AkCkAmBoBeDkAmBe@w@e@w@_@_Ad@|@`@fAp@|@j@n@h@z@h@dAj@`Ax@^l@z@d@jAPjAh@p@r@^r@]x@Hl@x@ZhAJrAdANz@Rz@\\p@dAPjAHlA}@xDe@tAo@c@i@eAf@v@b@|@j@p@l@r@b@bAn@n@`@`An@l@p@f@v@Zp@d@v@^n@l@z@L`AL|@Gr@Y~@Y`ACf@aAd@x@DxAV|A^zA\\nAXlA\\jA\\jAXpAZnADnAf@z@h@t@b@z@`@bALrAB|AMdB_@nAN|Ad@|Ad@tA`@`A^dA`@~@n@~@l@|@`@`A\\lAb@fAb@z@d@x@\\fAh@fAh@`A`@|@|@@p@f@b@z@^lA@tAZrAh@t@l@nANjA?rAt@dAr@Vp@\\r@z@j@r@r@t@`@~@TjADpAd@v@v@j@n@r@`@~@r@`APhALrANzADlAFnANrAx@n@r@\\`AEx@Pz@HI`BTlA`AOd@x@p@d@^`Ap@^t@NCxAEpAYrAOtAIxA[pA","participants":[],"sommets":[{"id":"6950","sommet":"Garten","altitude":"2040","lat":"46.6328","lng":"7.32845"}],"topos":[{"id":"9112","nom":"Garten depuis Jaun"}],"depart":{"id":"4153","depart":"Jaun","altitude_dep":"1021","lat":"46.6113","lng":"7.29053"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/VV3Qw.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/IPt8N.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/5CRGV.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/a659R.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/cV8Ro.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/7Waw6.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/XzCYo.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/JUMiZ.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/58dvB.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/rX0Tc.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/PWQGi.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/28yk1.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/bJVvE.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/rr7Zt.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/F8Mtw.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/tWcZ4.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/lQhKD.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181179\/2Y5Fv.jpg"}]},{"id":"181178","titre":"Dent de Crolles - Une 🦷 dans le jardin 🤩😍🤩","orientation":"SW","denivele":"850","dif_ski":"4.1","recit":"Itinéraire suivi : Topo en passant le long de la Gorgette<br>Horaires : 5h45 - 8h15<div><br><\/div><div>Session de rattrapage ce jour. Après notre sortie loose de mercredi dernier. Nous nous rattrapons ce jour. Cette fois-ci aucun problème pour monter au parking d'hiver. La trace tassée sous la forêt nous permet de monter efficacement. On met un peu de rythme pour se réchauffer car ça meule un peu dans ce pays ! Au-dessus, le paysage est féérique ! On ne s'en lasse pas de ces couleurs qui changent au fur et à mesure que le soleil se lève. Dans la prairie, la trace de montée a été quelque peu effacée par le vent. Gladys s'emploie à retracer. On arrive au pied du Pas de l'Oeille peu avant 7h. On se motive pour gravir le sommet. Court passage à pieds pour passer un ressaut, je ferais tout le reste à ski ! Merci aux prédécesseurs pour la trace !&nbsp;<\/div><div><br><\/div><div>Au sommet, ambiance toujours magique quoique quelque peu ventée. On ne traine pas, saluons un solitaire arrivant peu après nous puis on file dans le pas. Ca passe super bien, les ressauts sont comblés ! Le bonheur. 2 ou 3 traces filent vers la Gorgette (damned, elle ne reste même plus 48h vierge celle-ci !). Nous apprendrons de source plus ou moins sûre que l'auteur du méfait est Skitourien (n'est-ce pas Tibalt ?). On suit plus ou moins ces traces avant de tirer vers la prairie et de s'octroyer un champ encore vierge de trace nous envoyant directement au paradis.&nbsp;<\/div><div><br><\/div><div>Retour par la route pour préserver les semelles. En bas, le parking se rempli doucement, nous pouvons aller bosser !&nbsp;<br><br><\/div>","cond":"Météo\/températures : Beau temps, des nuages arrivant par l'Ouest. Frais au parking (-5.5°C), plus doux au dessus.&nbsp;<br>Conditions d'accès\/altitude du parking : Route déneigée, un peu de neige au-dessus de Baure \/\/ 1200m<br>Altitude de chaussage\/déchaussage : 1200 \/ 1200m<br>Conditions pour le ski : Excellentes pour une fin Novembre. Neige globalement poudreuse, parfois un peu croutée près des rochers. Un peu trafolée mais il reste de la place.&nbsp;<br><br>Conditions nivo et activité avalancheuse : RAS, quelques accus sur le haut.&nbsp;","skiabilite":"4","date":"1764284400","mois":"11","annee":"2025","auteur":{"id":"10548","pseudo":"Em42"},"massif":{"id":"11","nom":"Chartreuse"},"gpx":"\/sorties\/gpx\/181178.gpx","encoded":null,"participants":[{"id":"22142","pseudo":"Glad38"}],"sommets":[{"id":"198","sommet":"Dent de Crolles","altitude":"2062","lat":"45.308","lng":"5.8554"}],"topos":[{"id":"174","nom":"Dent de Crolles, Pas de l'Oeille"}],"depart":{"id":"142","depart":"Route du Col du Coq","altitude_dep":"1200","lat":"45.2965","lng":"5.84543"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/gOi92.jpg","com":"Départ en forêt&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/QdkuD.jpg","com":"On remonte la prairie&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/aWBBW.jpg","com":"Le jour va se lever&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/hjAkt.jpg","com":"Le Grésivaudan&nbsp;&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/ENhy9.jpg","com":"C'est parti pour le Pas&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/j1Mdh.jpg","com":"La vue s'élarige&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/uJKz5.jpg","com":"De vire en vire&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/rrrrd.jpg","com":"Pente sommitale&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/vliZJ.jpg","com":"C'est beau&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/914TS.jpg","com":"L'Oeille&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/MoJxq.jpg","com":"Glad'&nbsp;&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/cEMiq.jpg","com":"La croix&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/dT0Bk.jpg","com":"Le nord&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/XWTDY.jpg","com":"Descente !&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/aUcYR.jpg","com":"C'te vue !&nbsp;&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/NN1s2.jpg","com":"Glad'&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/ngTH1.jpg","com":"Sous l'Oeille&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/REqmB.jpg","com":"Cherchez Charlie&nbsp;&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/ax2tX.jpg","com":"Glad'&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/W47zd.jpg","com":"...&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/OTvnQ.jpg","com":"Le soleil se lève&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/RTSGf.jpg","com":"On la veut comme ça tout l'hiver !&nbsp;&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/j26gY.jpg","com":"Glad'&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181178\/AV0Gu.jpg","com":"Fin de matinale !&nbsp;&nbsp;"}]},{"id":"181174","titre":"Dent de Crolles - Une prairie ou deux…","orientation":"SW","denivele":"1000","dif_ski":"2.3","recit":"Itinéraire suivi : prairie à deux reprises, jusqu’au pied du pas<br>Horaires : 10h - 14h","cond":"Météo\/températures : brouillard avec quelques éclaircies\/ froid<br>Conditions d'accès\/altitude du parking : déneigé&nbsp;<br>Altitude de chaussage\/déchaussage : parking<br>Conditions pour le ski : poudre en cours de tassement<br><br>Conditions nivo et activité avalancheuse : ras<br><div><br><\/div><div>Première de l’année, on va profiter des grosses chutes des derniers jours.&nbsp;<\/div><div>Étonnamment la neige n’est pas en poudre 5 étoiles, elle se tasse déjà à cette altitude.&nbsp;<\/div><div>Et côté météo, bah on est resté dans le nuage 😂&nbsp;<\/div><div><br><\/div><div>Mais toujours aussi plaisant la première, surtout avec ces conditions!<\/div>","skiabilite":"4","date":"1764198000","mois":"11","annee":"2025","auteur":{"id":"15001","pseudo":"Mickey38"},"massif":{"id":"11","nom":"Chartreuse"},"participants":[],"sommets":[{"id":"198","sommet":"Dent de Crolles","altitude":"2062","lat":"45.308","lng":"5.8554"}],"topos":[{"id":"174","nom":"Dent de Crolles, Pas de l'Oeille"}],"depart":{"id":"142","depart":"Route du Col du Coq","altitude_dep":"1200","lat":"45.2965","lng":"5.84543"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181174\/eWHZV.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181174\/MCQ5n.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181174\/zIGWi.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181174\/5jvF3.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181174\/8FAq0.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181174\/Tj1zf.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181174\/RHutH.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181174\/czGyB.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181174\/vxmH2.jpg"}]},{"id":"181173","titre":"Tricotage au Mt Joux depuis la princesse","orientation":"NW","denivele":"783","dif_ski":"2.1","recit":"Itinéraire suivi : départ Princesse puis tricotage autour du Mt Joux<div>avec Phil, JC et Christophe<br>Une belle journée pour profiter des conditions exceptionnelles. Pisteurs et dameurs sont au travail, on essaie de ne pas déranger. Un peu de monde dans tous les secteurs sauf au Joly où on n'a vu personne (on n'y est pas allé).<div>Des moments magiques aujourd'hui avec un parhélie qui a duré environ 30 minutes puis de la bonne poudreuse sur toutes les orientations. Comme on dit : ce qui est pris n'est plus à prendre!<\/div><div>Les photos sont sans trucage!!!<br><br><\/div><\/div>","cond":"Météo\/températures : beau, bise.<br>Conditions d'accès\/altitude du parking : ras. nouveau parking avec sens de circulation<br>Altitude de chaussage\/déchaussage : 1050<br>Conditions pour le ski : poudre et poudre. plus la journée passait et meilleure elle était!<div>ça commence à être bien tracé mais il y a encore de la place.<br><br>Conditions nivo et activité avalancheuse : minage probable le matin sur le Joly et Côte 2000<br><\/div>","skiabilite":"5","date":"1764198000","mois":"11","annee":"2025","auteur":{"id":"2645","pseudo":"jeronimo"},"massif":{"id":"21","nom":"Beaufortain"},"participants":[],"sommets":[{"id":"2466","sommet":"Mont d'Arbois","altitude":"1839","lat":"45.8551","lng":"6.66884"}],"topos":[{"id":"3226","nom":"Mont d'Arbois, Par les pistes"}],"depart":{"id":"1392","depart":"Demi Lune","altitude_dep":"1050","lat":"45.8801","lng":"6.6412"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181173\/NupOS.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181173\/nUFux.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181173\/DOJhO.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181173\/fQyBA.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181173\/xYqUg.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181173\/xdLZp.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181173\/o1dbx.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1811\/181173\/d7tJb.jpg"}]},{"id":"181171","titre":"Quermoz, Crête de la Bagnaz&nbsp;","orientation":"W","denivele":"1420","dif_ski":"2.1","recit":"Itinéraire suivi : Cf Trace: Naves - Lac des Bozons - Quermoz - Col du Va - Crête de la Bagnaz - La Bagnaz - crête du Dzonfié - Nant du Beurre - Naves.<div>Récit : Partis initialement pour faire le mont de la Chambre à Méribel, nous avons changé nos plans à cause de la&nbsp; circulation arrêtée à l'entrée d'Aigueblanche. Du coup sortie à Aigueblanche pour prendre la direction de Naves. Une seule voiture sur le parking. Un peu froid&nbsp; (-8°) mais sans comparaison avec notre dernière sortie. Direction le Quermoz en suivant une&nbsp; belle mono trace serpentant dans la foret mais qui,&nbsp; malheureusement pour nous,&nbsp; s'est arrêtée au lac des Bozons.&nbsp; A&nbsp; partir de là&nbsp; trè...s gros traçage pour rejoindre le Quermoz. Au sommet nous avons rencontré 3 personnes qui venaient de Montgirod . Dépeautage et bascule dans une belle combe coté est sur une centaine de mètres, poudreuse de rêve. Repeautage, re traçage pour rejoindre le col de Va puis la crête de la bagnaz jusqu'à l'appoint des chalets de la bagnaz. Dépeautage et descente jusqu'aux chalets pour notre habituel casse croute. Aux Chalets, lorsque on déchausse, ca se complique,&nbsp; beaucoup de neige, ca enfonce vraiment (50cm par endroit) et il faut tasser cette dernière pour arriver a se faire une mini plateforme pour poser&nbsp;<span style=\"letter-spacing: 0.03em;\">nos affaires et sortir nos victuailles. Il commence de plus à se faire tard (14h), nous avons perdus beaucoup de temps et d'énergie avec ces gros traçages et ce malgré de bons relais. Repeautage ensuite&nbsp; pour une ultime montée en direction du Dzonfié. Descente dans le combe NE pour rejoindre le nant du beurre. Superbe poudreuse&nbsp; mais les&nbsp; jambes ne sont plus vraiment au rendez vous.<\/span><\/div><div>Au Nant du Beurre; nous attaquons&nbsp; la descente sur Naves, en temps normal les pistes de ski de fond permettent de prendre de la vitesse&nbsp; et surtout de la glisse pour arriver au \"Tovet\" avant la partie finale en foret mais là&nbsp; nous sommes face à un champs&nbsp; vierge à l'exception d'une seule trace de raquettes avec des trous énormes. Nous avons décidé de suivre cette trace en file indienne pour gagner du temps .<span style=\"letter-spacing: 0.03em;\">Ca enfonçait et ça poussait dur pour le premier, ça glissait pour<\/span><span style=\"letter-spacing: 0.03em;\">&nbsp;le second qui tassait les quelques trous restant,&nbsp; &nbsp;ça glissait&nbsp; parfaitement pour le troisième qui devrait&nbsp; même ralentir pour éviter d'emboutir ses prédécesseurs.&nbsp; Descente donc lente lente et laborieuse pour cette longue partie plate avant d'atteindre le Tovet et la descente&nbsp; finale foret .<\/span><\/div><div><span style=\"letter-spacing: 0.03em;\">En final grosse sortie, beaucoup de neige au dessus de 1600m, des traçages conséquents, pas beaucoup de dénivelé à la vue du temps passé,&nbsp; mais vu la quantité de neige et l'énergie dépensée pour la trace ca valait bien dixit Jacques une sortie à 1800D+.<\/span><\/div><div>Participants :&nbsp; Jacques, Gilbert, Jean-Robert<br>Horaires :9h30 -16h30<br><br><\/div>","cond":"Météo\/températures :&nbsp; froid&nbsp; (-8° au départ à 9h30)&nbsp;<br>Conditions d'accès\/altitude du parking : Naves<br>Altitude de chaussage\/déchaussage : 1310<br>Conditions pour le ski : très bonnes. Ps : Note \"Excellente\" non mise car nous nous avons beaucoup ramé en descente depuis le nant du beure pour rejoindre Naves, beaucoup de plat ou nous avons du beaucoup poussé en suivant une mono trace unique massacrée par des trous (raquettes).<br><br>Conditions nivo et activité avalancheuse : RAS, énormément de neige au dessus de 1600m","skiabilite":"4","date":"1764198000","mois":"11","annee":"2025","auteur":{"id":"30346","pseudo":"JeanRo"},"massif":{"id":"21","nom":"Beaufortain"},"gpx":"\/sorties\/gpx\/181171.gpx","encoded":"u_auG}~xf@v@Bj@m@r@Sj@k@p@a@ZcA^_A[cAc@w@KkAWeAFkAAmAc@cAGkALiAb@y@HkAn@g@h@o@WgA[cAXcAj@o@d@u@h@q@^}@^_AXcAZcAEkASgASiAGkAGmARgAImAKkAQiAIkACmAd@y@p@Wt@Qr@Qp@]v@Gt@@`@{@PiAi@s@UgAFkAXcAAoAc@w@]_AUgAg@w@QiAFkACmASgABmAt@Ct@@t@Et@Nv@Cp@\\b@z@^|@p@\\p@\\YcA[aA_@_AGkAg@u@i@w@]aAm@i@q@a@o@_@g@w@YcAYeA_@_ABmA[cAOgAi@s@a@{@u@Mk@k@[cA]_Ac@}@k@k@s@Yi@q@m@k@u@Qh@s@t@Cv@Cr@Ht@?v@Dr@Pt@Jt@Jt@Jt@Av@Bt@Ht@Dt@Jt@Fr@Un@g@GoAOiAVeAl@i@l@k@^{@JkAOiAc@y@k@m@iA}@q@g@o@i@q@g@q@i@o@g@q@i@o@g@o@g@q@i@k@k@i@s@c@y@m@g@g@u@e@w@g@w@g@s@k@k@o@g@k@o@k@m@o@g@]_A[aAg@s@e@eAe@cAi@s@g@s@UeAWeAWeASgAWeA_@aAQiALkAs@Wo@c@q@i@u@BQhALkAw@Ww@K{@Io@a@e@y@MiAg@u@k@n@k@dAu@Ru@Au@Ou@Js@Ps@Ts@Va@z@AlAOhAs@Ss@Qu@Au@?{@?w@Ou@So@c@s@_@u@?u@Eu@Iu@Iw@@q@Zw@Lo@a@s@Ys@[s@Ww@B{@Fs@Lu@Kq@^u@Cq@a@u@Eu@Pu@Bs@Nu@Bs@Tu@Ru@Bu@QWkAe@u@]_AYcAm@i@k@o@c@w@c@{@g@s@i@s@OuASmAKqAQmAIqAEqA@oAJmAMkAAkA@wABkA\\qAZgA\\eAh@y@^_AGmAIyAJkAZeAVoAd@aAXaAs@Ou@Ju@@u@As@Ta@}@[aAi@o@s@Zs@Ru@Nu@Ji@n@q@b@u@Ru@@c@y@s@Us@Vu@Nu@Da@z@g@t@cAI}@K}@Ou@Qu@C[`AAlAYbAQpADtA_@bAr@d@z@Jr@l@^~@r@\\JjAd@|@z@?ZdA?lAUjAShAa@pA_@dAe@lA]hAUfAWfAQhAErAGxAWrA_@`Ac@x@q@t@_@~@WrAEnAIjAOjAg@p@w@Fq@