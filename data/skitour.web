753","lng":"7.23528"}],"topos":[{"id":"6602","nom":"Cime de Frémamorte, Face SW directe"},{"id":"1686","nom":"Tête des Tablasses, Par la face Sud"},{"id":"3845","nom":"Tête des Tablasses, Tour"}],"depart":{"id":"458","depart":"Le Boréon (Parking d'hiver du col de Salèse)","altitude_dep":"1580","lat":"44.12","lng":"7.27398"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186606\/L4pS1.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186606\/Vriok.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186606\/CMrKN.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186606\/LzNoB.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186606\/rSCVC.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186606\/rJPX4.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186606\/zLmOL.jpg","com":"&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186606\/dpRje.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186606\/yhILB.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186606\/EpioB.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186606\/EKWrs.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186606\/IMGfV.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186606\/eaGuA.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186606\/NvuIc.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186606\/BPogC.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186606\/TjA8X.jpg"}]},{"id":"186605","titre":"Orionde, Tricotage poudreux de tous côtés !&nbsp;","orientation":"T","denivele":"1500","dif_ski":"3.1","recit":"Itinéraire suivi : Topo jusqu'au sommet puis : 1 descente NE > sommet > 1 descente est > sommet > 1 descente W jusque sous la cabane > sommet > descente nord.&nbsp;<br>Horaires : 07h00 - 13h00&nbsp;<div><br><\/div><div>Enfin libre après une chute de neige, j'avais pour projet de refaire cette belle brèche ouest du Grand Replomb. Après un départ relativement matinal, je tracerai toute la montée jusqu'à Orionde.&nbsp;<\/div><div>Une fois en haut, la traversée pour rejoindre la montée vers le couloir du grand Replomb ne m'inspire pas confiance... La neige récente avait tendance à partir sous les skis, plus quelques vielles coulées dans le couloir ne laissant pas espérer du grand ski, finissent par me convaincre de changer de plan.&nbsp;<\/div><div>Ce sera du tricot autour d'Orionde.&nbsp;<\/div><div>Il est 09h30, les faces est doivent encore être en poudre légère. C'est parti pour une première descente, puis une deuxième avant les grosses chaleurs. Entre temps, un poursuivant ira explorer la pente sud-ouest ; salut à toi, rencontre sympa. Je le retrouve au sommet et on fera une belle descente ouest en neige bien légère. Un régal malgré le fond dur.&nbsp;<\/div><div>Remonté au sommet, je terminerai par la descente classique en nord. Un départ du sommet déclenchera une mini coulée de neige lourde sans conséquence.&nbsp;<\/div><div><span style=\"letter-spacing: 0.03em;\">La descente dans les vernes était encore correcte à 12h45 mais c'était en train de s'humidifier.<\/span><\/div><div><span style=\"letter-spacing: 0.03em;\"><br><\/span><\/div><div><span style=\"letter-spacing: 0.03em;\">Peu de monde dans le secteur mais des départs un peu tardifs à mon sens.&nbsp;<\/span><\/div><div><span style=\"letter-spacing: 0.03em;\">2 skieurs sont allés s'aventurer sous la brèche mais n'y sont pas montés. Je pense avoir fait le bon choix le matin ; j'y retournerai quand ce sera transfo !&nbsp;<\/span><\/div><div><span style=\"letter-spacing: 0.03em;\"><br><\/span><\/div><div><span style=\"letter-spacing: 0.03em;\">&nbsp;&nbsp;<\/span><\/div><div><br><\/div>","cond":"Météo\/températures : Beau temps sans vent avec quelques passages nuageux à partir de 12h00 \/ 3°C au départ, 11°C au retour&nbsp;<br>Conditions d'accès\/altitude du parking : Pont de la Betta 1300 m&nbsp;<br>Altitude de chaussage\/déchaussage : Pont de la Betta 1300 m \/ Epingle 1330 m (départ vallon Vénétier)&nbsp;<br>Conditions pour le ski :&nbsp;<div>Une bonne vingtaine de cm de poudre fraiche posée sur fond regelé.&nbsp;<\/div><div>On sent un peu le fond dur par endroit mais la poudre est restée légère à l'ombre et tôt le matin en versant ensoleillé.&nbsp;<\/div><div>Humidification rapide sur les faces au soleil.&nbsp;<\/div><div>Le border cross de passe pas à la descente hors ski cailloux. Préférer le retour par la prise d'eau.&nbsp;<br><div><br>Conditions nivo et activité avalancheuse : La couche récente a tendance à glisser sur le fond dur. Départ d'une mini coulée de poudre lourde sous le sommet d'Orionde (face NE).&nbsp;<br><\/div><\/div>","skiabilite":"4","date":"1774220400","mois":"03","annee":"2026","auteur":{"id":"19810","pseudo":"Den's"},"massif":{"id":"12","nom":"Belledonne"},"participants":[],"sommets":[{"id":"460","sommet":"Orionde","altitude":"2041","lat":"45.2105","lng":"5.9742"}],"topos":[{"id":"609","nom":"Orionde, Combe NE"}],"depart":{"id":"22","depart":"Prabert","altitude_dep":"1220","lat":"45.2327","lng":"5.98874"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/Iwex6.jpg","com":"&nbsp;La Dent matinale !&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/9VRx0.jpg","com":"&nbsp;C'est tout droit !&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/bJaVq.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/H7YiF.jpg","com":"La Dent de Crolles se cache&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/tTbev.jpg","com":"Un peu de compagnie&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/tu66p.jpg","com":"La vallée du Vénétier au loin&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/8AfzC.jpg","com":"Au sommet d'Orionde&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/A0hYU.jpg","com":"Slurp !&nbsp;&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/7jbwX.jpg","com":"Slurp² !&nbsp;&nbsp;&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/KaqTk.jpg","com":"&nbsp;Encore tout poudre !&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/ck0yj.jpg","com":"&nbsp;Deuxième descente.&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/i8XNd.jpg","com":"Ça chauffe en Est mais c'était le bon moment pour en profiter&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/IjIId.jpg","com":"Les deux premiières descentes&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/5XURi.jpg","com":"&nbsp;L'objectif initial"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/fTVsn.jpg","com":"&nbsp;3ème descente"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/qnaus.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/A3eJO.jpg","com":"De belles pentes sous la cabane&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/revDG.jpg","com":"Toujours très bon !&nbsp;&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/m2vy4.jpg","com":"&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/5m1f9.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/S3906.jpg","com":"Mini coulée sur une portion de neige lourde sous le sommet&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/00qDW.jpg","com":"Dernière et 4ème descente&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186605\/YK6B6.jpg","com":"L'incontournable Ferrouillet nord.&nbsp;&nbsp;"}]},{"id":"186604","titre":"Sommet de La Lauzière","orientation":"N","denivele":"980","dif_ski":"3.1","recit":"Itinéraire suivi : Valpreveyre , Bergerie Pierres Écrites, Sommet en AR<br>Horaires : 7H30 \/ 13h30<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Sortie CAF&nbsp; Guillestrois\/Queyras sous \"l’autorité\" de Nicolas&nbsp;&nbsp; avec Nadège, Marc, Lydie, Bernard, Marine, Cory. Après un départ friqué nous rejoignons Valpréveyre&nbsp; où nous faisons les tests DVA.&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Sur la Trace de MARINE nous passons à coté de la bergerie qui visiblement est occupé !! et poursuivons vers notre objectif du jour dans 30, 40cm de poudre et dans des pentes qui avoisine >=30°. BERA =3&nbsp; donc nous prenons les espaces de sécurité.Un léger vent d'ESt nous accueil&nbsp; au sommet . Photos , contemplation pour ceux qui découvre les lieux et nous nous lançons dans la \"peuf\" *****. encore vierge de traces ","cond":"Météo\/températures : Beau , T: -10° à 7H30 ; 7°C à 13H00<br>Conditions d'accès\/altitude du parking : RAS&nbsp; <br>Altitude de chaussage\/déchaussage : Parking Téléski La Brune !<br>Conditions pour le ski : Poudre sur l'ensemble de l'itinéraire. de quelques cm le long de la piste jusqu'à Valpreveyre jusqu'à>=40cm après 'la Bergerie des Pierres Écrites.Les dernières chutes de neige nous ont offerts un manteau quasi vierge.et par chance le vent n'a pas œuvré dans ce secteur .&nbsp; <br><br>Conditions nivo et activité avalancheuse : rien observé ni ressenti. Un BERA&nbsp; à 3 ,&nbsp; avons appliquez les consignes de sécurité dans les pentes >= 30°","skiabilite":"5","date":"1774220400","mois":"03","annee":"2026","auteur":{"id":"15873","pseudo":"MH 05600"},"massif":{"id":"6","nom":"Queyras - Alpes Cozie N"},"participants":[],"sommets":[{"id":"2579","sommet":"Bric Bouchet","altitude":"2998","lat":"44.8217","lng":"7.02361"},{"id":"3157","sommet":"Colette de Gilly","altitude":"2366","lat":"44.7966","lng":"6.96027"},{"id":"1681","sommet":"Tête du Pelvas","altitude":"2929","lat":"44.7894","lng":"6.99972"},{"id":"1636","sommet":"Mait d'Amunt","altitude":"2804","lat":"44.7983","lng":"7.00972"}],"depart":{"id":"104","depart":"le Roux d'Abriès","altitude_dep":"1750","lat":"44.8218","lng":"6.94309"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186604\/29UQR.jpg","com":"promenons nous dans le bois !! "},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186604\/OBcYH.jpg","com":"passage à la Bergerie Des Pierres Écrites "},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186604\/fG65z.jpg","com":"Le Mait d'Amunt "},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186604\/RIssw.jpg","com":"sommet de la Lauzière "},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186604\/zkGbj.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186604\/WyRl4.jpg","com":"&nbsp;Marc en plein effort !!"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186604\/p16d2.jpg","com":"l'incontournable !"},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186604\/FiNfH.jpg","com":"la Taillante&nbsp; "},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186604\/6pjCt.jpg","com":"poudre plaisir ***** "},{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186604\/Epe8Y.jpg","com":"l'équipe&nbsp; "}]},{"id":"186603","titre":"Dent du Pra depuis le Pleynet","orientation":"N","denivele":"1193","dif_ski":"3.3","recit":"<div>Itinéraire suivi : presque comme le topo variante col du vouteret, mais sommes passés par le vallon qui précède celui qui accède au col du Vouteret, l'avons remonté le plus haut possible pour en sortir (50m à pied) par la droite et rejoindre vers 2450m l’arête qui sépare vallon du Pra et vallon de la Belle Etoile. Stop sur cette arête 50 m sous le sommet. Gros travail de traçage final par Stephen (à ski puis à pied dans une&nbsp; neige lourde et profonde). Plusieurs groupes en ont&nbsp; profité derrière nous ;=)<\/div><div>Neige plutot décevante à la descente (lourde, profonde,quelques bonnes courbes ici ou là dans les zones restées froides)<\/div><div>Horaires : 8h30 sommet 13h retour 14h15<\/div><div>Avec Stephen et Thierry<\/div>","cond":"Météo\/températures :beau au début puis très variable voire franchement bouché<br>Conditions d'accès\/altitude du parking : RàS<br>Altitude de chaussage\/déchaussage : au Pleynet&nbsp;<br>Conditions pour le ski : bon enneigement sur tout l'itinéraire, neige globalement lourde à très lourde avec bottage<br>Conditions nivo et activité avalancheuse : RàS hormis boulettes et escargots","skiabilite":"2","date":"1774047600","mois":"03","annee":"2026","auteur":{"id":"3012","pseudo":"randoski69"},"massif":{"id":"12","nom":"Belledonne"},"participants":[],"sommets":[{"id":"85","sommet":"Dent du Pra","altitude":"2623","lat":"45.2387","lng":"6.0404"}],"topos":[{"id":"778","nom":"Dent du Pra, Versant Nord"}],"depart":{"id":"21","depart":"Le Pleynet","altitude_dep":"1430","lat":"45.2703","lng":"6.05497"},"photos":[]},{"id":"186601","titre":"Pas du pin, perte de piolet","orientation":"W","denivele":"1100","dif_ski":"3.1","recit":"Itinéraire suivi : Direction col aigleton et bifurcation pour le couloir du pas des pins avec de belles traces faites par mes compagnons de cordée, merci !&nbsp;<br>Horaires : 9h-13h<br>Bonne pioche pour une sortie après une bonne quantité de neige fraîche (40cm).&nbsp;<div>Seul bémol à notre virée, j'ai perdu un piolet Orange Petzl sans Dragoons, sous le couloir. Sûrement après une petite chute. Si qqn le retrouve, je lui offrirai mes sincères remerciements et une petite mousse !&nbsp;<\/div><div>Bon ski et profitez bien<\/div>","cond":"Météo\/températures : Beau et dans les nuages fin de matinée \/ 5-10°<br>Conditions d'accès\/altitude du parking : Bonne \/<br>Altitude de chaussage\/déchaussage : parking<br>Conditions pour le ski : Bonne en Ouest, mais vite lourde dans la descente en Sud et bordercross bien rempli<br><br>Conditions nivo et activité avalancheuse : petite purge dans le couloir","skiabilite":"4","date":"1774220400","mois":"03","annee":"2026","auteur":{"id":"52818","pseudo":"aphorisme"},"massif":{"id":"12","nom":"Belledonne"},"participants":[],"sommets":[{"id":"65","sommet":"Col de l'Aigleton","altitude":"2266","lat":"45.2309","lng":"6.0369"},{"id":"112","sommet":"Pas du Pin","altitude":"2203","lat":"45.2253","lng":"6.0336"}],"depart":{"id":"22","depart":"Prabert","altitude_dep":"1220","lat":"45.2327","lng":"5.98874"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1866\/186601\/FR6jx.jpg"}]},{"id":"186599","titre":"Neige fraîche et grand soleil au Col du Sarvatan","orientation":"E","denivele":"800","dif_ski":"2.3","recit":"Itinéraire suivi : selon topo pour le Col de Sarvatan<br>Horaires : départ 7h30, au col passé 10h<div>Avec Michel et Marc<br><br><\/div>","cond":"Météo\/températures : Soleil, bien froid au départ&nbsp;<br>Conditions d'accès\/altitude du parking : dégagé&nbsp;<br>Altitude de chaussage\/déchaussage : 1600m<br>Conditions pour le ski : neige fraîche mais pas si légère (vent, soleil), bien dans l'ensemble<br><br>Conditions nivo et activité avalancheuse : 10cm de fraîche environ, pas de coulée récente&nbsp;","skiabilite":"4","date":"1774220400","mois":"03","annee":"2026","auteur":{"id":"20469","pseudo":"gauthier78"},"massif":{"id":"19","nom":"Lauzière - Cheval Noir"},"gpx":"\/sorties\/gpx\/186599.gpx","encoded":"ugetGi{ye@w@Sq@`@m@g@u@Bw@Cs@Yk@i@e@y@g@s@YcAEmAk@o@u@Ou@Gu@Hu@Gu@Oo@g@u@Uu@Jw@Hs@Lw@@w@Ag@r@@lADnAMjAc@z@e@v@e@v@g@v@i@p@o@f@o@`@o@b@VdAf@p@g@t@u@Ls@Hw@BSfAf@r@l@j@n@f@j@n@k@m@m@g@o@c@u@Ms@Pq@`@q@\\u@Ne@v@i@p@u@@QhAs@Lw@Ds@Rs@Vq@`@s@Nu@Ns@Pq@\\k@l@k@l@q@^u@Bu@Nu@Ju@Pq@Xu@Fu@Fq@^s@To@^a@z@c@z@]`Ag@t@WdAi@n@q@d@s@Ts@Zk@l@i@p@a@|@c@x@o@d@WdAIjAe@v@IlAm@f@BlAq@_@QfAm@g@u@Ju@Li@p@w@Lm@b@g@s@w@?s@No@e@u@?c@x@o@e@u@Iu@JQfAk@n@e@v@Y`Ao@f@s@Su@Fo@e@GlAYbAUfAq@XTdAu@NNhAi@p@m@b@e@v@GlADqAl@g@FqAr@Xl@s@VgAp@a@WiAXqA?uARkAt@Ix@Vh@z@n@a@d@_AOkAViAp@o@v@a@x@Zr@Mx@Qt@Yl@n@MlAZmAv@Ot@APjATgAz@Bt@Kx@Sn@o@p@g@x@?z@LGmABoAVmAh@o@z@_@l@aA\\gAr@m@d@w@v@c@t@Wt@]h@{@XcAb@aAz@_@r@WHqAp@_@v@Ov@B|@F`@{@t@Dv@`@j@q@z@WRiA^}@v@g@p@i@r@Yv@\\bAE^mAp@g@x@^x@Uv@k@b@}@r@[TiAO}At@c@v@r@n@c@|@[v@Ht@\\r@Ip@j@n@h@f@r@HlAl@g@KkAWiAGoAp@a@EoA_@_As@k@GqAt@i@x@Sp@m@h@_Ah@y@j@y@d@{@XiAGmAKiAH{Av@Ip@^|@Kx@S`AQ`ATp@n@t@R|@Ex@Lx@Gz@Th@v@NlAj@`A^~@VzAx@Np@f@t@d@p@b@n@v@t@WZ_AFoAo@y@rBfDkAiB","participants":[],"sommets":[{"id":"6313","sommet":"Col de Sarvatan","altitude":"2439","lat":"45.4424","lng":"6.34703"}],"topos":[{"id":"826","nom":"Rocher Sarvatan, Normale"}],"depart":{"id":"2503","depart":"St François Longchamp (office du Tourisme)","altitude_dep":"1600","lat":"45.4171","lng":"6.364"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1865\/186599\/Ie6ii.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1865\/186599\/P6Jdb.jpg"}]},{"id":"186598","titre":"Traversée (héroïque) sur l'autoroute du soleil","orientation":"T","denivele":"940","dif_ski":"2.1","recit":"Itinéraire suivi : Vallon de Corne, Traversée Héroïque, Fond du Vallon d'âne, Remontée vers le Vallon Froid, Descente Vallon froid puis piste jusqu'au Pk.<br>Horaires : Chaussage à 9H, Sommet de Corne à 10H45, Sommet du vallon Froid à 12H, Voiture 12H45<div><br><\/div><div>Un dépôt de marchandise à l'école nous empêchant de partir aussi tôt que le grand soleil du jour l'aurais demandé, on s'oriente vers le plus froid des vallons du Dévoluy.&nbsp;<\/div><div>Mais avant ça, nous aussi on veut faire notre petit tour sur l'autoroute du soleil en nous prenant pour des héros. Seulement 6 personnes, petite fréquentation, même pour un lundi.&nbsp;<\/div><div>On retrouve du calme en allant vers le Vallon froid, vide à 11H mais déjà bien (bien bien) pratiqué en matinée. En nord est, la neige qui a vu le soleil tôt est déjà bien dense. Les conditions de printemps vont vite être là. Remontée vers le Vallon Froid (merci pour la trace) en serrant les fesses pour finalement tombé sur ce qu'on est venu chercher. 25cm de poudre de ciné et quelques bons virages jusqu'en bas.&nbsp;<\/div><div><br><\/div>","cond":"Météo\/températures : iso à 2000, grand ciel bleu, trop chaud au fond des vallons<br>Conditions d'accès\/altitude du parking : RAS<br>Altitude de chaussage\/déchaussage : épingle sous le téléphérique - 1450m<br>Conditions pour le ski :&nbsp;<div>> Du haut de Corne au fond du Vallon d'âne : 25 cm poudre qui commence à se densifier et à bien s'humidifier, mais ski correct grâce au fond dur&nbsp; ***<br>> Du haut du Vallon Froid à la piste (pt 1736) : 25 cm de poudre encore froide *****<\/div><div>> Sur la piste : glissage tranquille sur la trace de montée pas encore ravagée par les raquettes (pour le moment...)<br>Conditions nivo et activité avalancheuse : Quelques purges dans les pentes les plus raides en ouest (avant la traversée héroïque et dans le vallon froid notamment). Encore aucune purge sous les rochers en est, mais vu la chaleur, ça ne va pas tarder.&nbsp;<br><\/div><div><br><\/div><div>Ps : évidemment la traversée héroïque passe sans la moindre difficulté. Elle est pleine comme jamais. Taillée de vaste escaliers aussi larges que ceux du Titanic. Enjoy !&nbsp;<\/div>","skiabilite":"4","date":"1774220400","mois":"03","annee":"2026","auteur":{"id":"24029","pseudo":"Alxx"},"massif":{"id":"8","nom":"Devoluy"},"participants":[{"id":"34276","pseudo":"Missou"}],"sommets":[{"id":"421","sommet":"Corne","altitude":"2111","lat":"44.6449","lng":"5.9306"},{"id":"210","sommet":"Crête d'Ane","altitude":"2019","lat":"44.6397","lng":"5.9493"}],"topos":[{"id":"548","nom":"Crête d'Ane, Tour de la Crête d'Ane"},{"id":"604","nom":"Pic de Bure, Combe Ratin"}],"depart":{"id":"210","depart":"L'Enclus (téléphérique du Pic de Bure)","altitude_dep":"1485","lat":"44.6614","lng":"5.93845"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1865\/186598\/3dxnZ.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1865\/186598\/5oljP.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1865\/186598\/AMOD7.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1865\/186598\/1V1d0.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1865\/186598\/zcYxn.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1865\/186598\/Jf4uN.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1865\/186598\/kUd6e.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1865\/186598\/NGTi2.jpg"}]},{"id":"186597","titre":"Col du Sabot","orientation":"SW","denivele":"973","dif_ski":"2.1","recit":"Itinéraire suivi : Le but était de faire les Aiguillettes & Côte Belle... Pour le moins optimiste ! On a pas du tout eu le temps... Finalement on a juste fait col de Sabot et on a commencé à faire Côte Belle, avant de faire demi-tour (faute de temps donc...). On s'est quand même bien amusé à faire la trace, et merci David pour le partage de celle-ci jusqu'au Col du Sabot 😁 !<br><br>Horaires : <br><div>7h40 départ du parking<\/div><div>9h40 Col du Sabot<\/div><div>11h40 Notre point le plus haut sur Côte Belle (où nous avons fait demi-tour)<br>12h40 Arrivée parking<\/div>","cond":"Météo\/températures : Pas froid mais beaucoup de vent du début jusqu'à 10h30 ~ 11h. Tourbillons de neige sous le sommet... On est monté juste avec nos hauts thermiques mais on a rajouté des couches à chaque arrêt !<br><br>Conditions d'accès\/altitude du parking : Parfait ! Premier arrivés, un peu moins d'une dizaine de voitures sur le parking lorsque nous avons fini la sortie.<br><br><br>Altitude de chaussage\/déchaussage : Chaussage : 1400m (parking), déchaussage : 1400m (parking)<br><br>Conditions pour le ski : Moyen... Le vent a décapé des zones et créé de grosses accumulations, du coup des gros changements de neige tous les deux mètres. Sauf un endroit ! Un bon 200m~300m sous notre point le plus de Côte Belle (là où nous avons fait demi-tour) en bonne poudreuse ! Là, que du bonheur !<br><br>Conditions nivo et activité avalancheuse : Attention beaucoup plus de vent qu'indiqué sur le BERA. Le risque réel est plus élevé ! Comme dit plus haut il y avait des tourbillons de neige sous les sommets, ça a bien brassé... Et ça (de la neige ventée) de partout ! On savait plus trop quoi pensé de tout ça alors on est resté safe... Si quelqu'un avec plus d'expérience que nous, et qui est passé au même endroit pouvait éclaircir tout ça dans les commentaires 😁","skiabilite":"3","date":"1774220400","mois":"03","annee":"2026","auteur":{"id":"49603","pseudo":"zephyrin.denonfoux"},"massif":{"id":"13","nom":"Grandes Rousses - Arves"},"gpx":"\/sorties\/gpx\/186597.gpx","encoded":"u}trGsied@m@d@s@Yu@Qs@Ys@Wo@g@w@@w@Bm@f@u@NMjAq@a@s@RNhAs@W?nAXbAu@?q@_@q@_@u@Su@BKhAu@Ms@Yu@Gq@b@u@Nu@Gs@Su@?w@Nq@Xk@n@k@n@e@t@i@r@i@n@u@Oc@{@i@o@w@M_AIEmARgAMkAw@Aq@\\m@g@i