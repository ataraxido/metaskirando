8\/180898\/ZXgVA.jpg","com":"Notre sommet du jour "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/B84L3.jpg","com":"Vue sur l'âne "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/M1g6v.jpg","com":"C'est parti !&nbsp; "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/gFFeJ.jpg","com":"Décaillé à souhait "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/C9dbP.jpg","com":"Powder !&nbsp; "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/h9BZv.jpg","com":"Suite "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/840Ak.jpg","com":"Replat à 2050m côté Italie "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/0flBp.jpg","com":"Glad' "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/pXxcQ.jpg","com":"Ca va se boucher "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/S2rhb.jpg","com":"Suite "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/ufPzB.jpg","com":"Vue sur notre couloir "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/1ocec.jpg","com":"Replat à 2450m "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/qLc9S.jpg","com":"Second sommet "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/LJLzn.jpg","com":"Un peu de neige revenue "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/rtNb6.jpg","com":"Glad' "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/WUmW2.jpg","com":"Sculptures "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/AsjPo.jpg","com":"Mauvaise troupe&nbsp; "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/KA83V.jpg","com":"Ca passe&nbsp; "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180898\/jGDqQ.jpg","com":"Fin de journée&nbsp; "}]},{"id":"180897","titre":"Font Sancte, écharpe N","orientation":"N","denivele":"1350","dif_ski":"5.1","recit":"Itinéraire suivi\/Horaires : Parking 9h, Sommet de l'écharpe 13h, retour 14h15<div><br><\/div><div>Avec Joseph nous sommes parti ce matin dans l'optique de skier un peu de raide à la Font Sancte. Donc direction l'écharpe N puisque c'est l'itinéraire le moins demandant en remplissage c'est qui est idéale pour un mois de novembre. Nous avons donc remontés la piste de ski jusqu'au lac St Anne puis nous nous somme dirigé vers le pied du couloir N en remontant à gauche de la moraine. D'ici la monté jusqu'en haut en crampons c'est déroulé sans encombres. Enfin la descente était en très bonne condition, la neige reste un peu changeante à cause du vent et il faut faire gaffe au shark mais nous nous sommes régalés !!!<\/div><div><br>[Youtube]\/jMAFfJtqVuw?feature=shared[\/youtube]<\/div>","cond":"Météo\/températures : -2°C au départ puis température négatives toute la journée ormi les petits passages au soleil en dessous du lac St Anne<div><br>Conditions d'accès\/altitude du parking : garé au parking des fonds de chauriondre<\/div><div><br>Altitude de chaussage\/déchaussage : chaussage sur la piste de ski à partir du petit plat avant la montée au lac (environ 2200m)<\/div><div><br>Conditions pour le ski : Très bonne en grande partie, un peu moins aux endroits touchés par le vent<br><br>Conditions nivo et activité avalancheuse : RAS, mais le vent a tout de même eu un impacts important sur la neige par endroits<br><\/div>","skiabilite":"5","date":"1762642800","mois":"11","annee":"2025","auteur":{"id":"44140","pseudo":"gaspard.andrillon"},"massif":{"id":"6","nom":"Queyras - Alpes Cozie N"},"participants":[{"id":"49120","pseudo":"jojo_andrilllon"}],"sommets":[{"id":"6884","sommet":"Font Sancte, point 3292","altitude":"3292","lat":"44.6076","lng":"6.79987"}],"topos":[{"id":"536","nom":"Font Sancte, épaule Est, couloir nord"}],"depart":{"id":"3983","depart":"Ceillac (Fond de Chaurionde)","altitude_dep":"1965","lat":"44.6298","lng":"6.82113"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180897\/adX7T.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180897\/OT3my.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180897\/RgTT2.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180897\/yX3M4.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180897\/yeWpe.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180897\/k5fxL.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180897\/mpobl.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180897\/xBcAL.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180897\/d3oEz.jpg"}]},{"id":"180896","titre":"col des Arses (approche VTTAE)","orientation":"NW","denivele":"1050","dif_ski":"2.2","recit":"<div>Itinéraire suivi : VTTAE posé à l'entrée du vallon de la Lenta , sur la route jusqu'au pont de l'Oulietta (c'est long...), puis combe nord-ouest à tracer jusqu'au col des Arses ;&nbsp;<\/div><div>Bonne neige à la descente, à condition de viser les contre pentes à l'ombre jusqu'au pont ; puis droit en dessous neige transfo jusqu'à l’épingle 2300. Fin par la route<\/div>Horaires : 4h30 en tout","cond":"Météo\/températures : grand beau, iso 2100, frais à l'ombre juste bien au soleil<br>Conditions d'accès\/altitude du parking : 2100, route Iseran fermée, mais approche VTTAE depuis Bessans&nbsp;<br>Altitude de chaussage\/déchaussage : 2100<br>Conditions pour le ski : un peu de tout selon orientation, transfo à poudre ancienne en passant par la croûte et le carton<br><br>Conditions nivo et activité avalancheuse : ras","skiabilite":"4","date":"1762642800","mois":"11","annee":"2025","auteur":{"id":"4942","pseudo":"Pierre-Alpin"},"massif":{"id":"18","nom":"Vanoise"},"participants":[],"depart":{"id":"2205","depart":"Bessans","altitude_dep":"1700","lat":"45.3203","lng":"6.99288"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180896\/uPQ1L.jpg","com":"arrivée au col des Arses"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180896\/WHtvA.jpg","com":"tout bon"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180896\/J29iX.jpg","com":"sous le pont de l'oulietta, couloir direct"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180896\/jg9Fv.jpg","com":"Albaron"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180896\/6WuGK.jpg","com":"retour vtt"}]},{"id":"180895","titre":"Week-end à Val Thorens- J2: Mont de Péclet","orientation":"NE","denivele":"1150","dif_ski":"2.1","recit":"<strong>Itinéraire suivi<\/strong> : Val Tho - piste Corniche - Col de la Chambre - Mont de Péclet - Lac de la Chambre - Mont de Péclet - Val Tho&nbsp;<div><br><strong>Horaires<\/strong> : 9h25 - 14h00<\/div><div><br><\/div><div>Deuxième jour sur Val Tho! Réveil sous le Grand ciel bleu, après une bonne nuit, seulement entrecoupée d'un \"intermède\" musical entre 1h30 et 3h... les voisins étaient en forme 😅<\/div><div>Le temps de ranger l'appart, les nuages arrivent... Bon, on verra bien! Départ à nouveau douchés par les canons. Pas super sympa mais on se doute bien qu'ils seront nos meilleurs amis tout à l'heure quand on descendra.<\/div><div><br><\/div><div>Direction le soleil, donc et le col de la Chambre, par la piste Corniche. Le ciel finit par se dégager et un petit test de la neige me fait me demander, si on n'aurait quand même pas dû aller côté Caron pout avoir quelque chose de plus skiable, parce là... c'est croûté... pas d'autre mot 😅<\/div><div>Un peu de neige dure dans la Goitschel me laisse espérer une portion de moquette... on croise les doigts 😅<\/div><div>Arrivés au col de la Chambre avec Gé, on décide d'enchaîner sur le Mont de Péclet en attendant Po et Co. Y a même une trace qu'on suit tranquillement jusqu'au sommet d'où on apprécie le 360.<\/div><div><br><\/div><div>On entame la descente... tranquille parce que c'est bien cartonné et que les requins ne sont parfois pas loin! On croise rapidement Po et Co qui en terminent et qui nous disent qu'elles nous attendront au soleil!<\/div><div>Nous, on poursuit... surtout pour arrondir le dénivelé parce que question ski, disons que c'est formateur 😅 on avait hésité à la montée mais finalement on descend côté Lac de la Chambre, en se disant que ça ne sera pas pire que ce qu'on vient de faire! Effectivement, c'est toujours bien carton, et c'est un peu le suspense pour savoir si on passe à travers ou pas 😁 Gé s'arrête lorsqu'on rejoint les pistes. Je poursuis un peu plus bas et trouve deux belles sections de poudre dense non ventée posées entre les plaques de neige à canons pour quelques godilles appréciables!<\/div><div>Je m'arrête juste sous le Lac et repars sans trop tarder, histoire de ne pas faire attendre ces dames! 😁<\/div><div><br><\/div><div>Je trace donc la piste et la suis bille en tête avant de me rendre compte que je ne vois pas les traces de Gé. Coup d'œil dans le rétro pour voir qu'elle a tracé là où on est descendus 😅 eh m*rde... demi-tour, pour prendre la trace... autant respecter le travail!<\/div><div>On retrouve donc Po et Co au soleil au sommet, nous attendant pour le casse-croûte!<\/div><div>La terrasse est très cool et on en profite grandement avant d'attaquer la descente!<\/div><div>On fait toujours gaffe sur le haut, même si c'est meilleur grâce aux traces précédentes qui ont damé le passage!<\/div><div>Sous le col de la Chambre, on retrouve 2 skieurs (et un chien), qui brisent la solitude du lieu! Côté ski, c'est bien de la croûte qui nous attend de pieds fermes... dur à skier 😬 tellement, que c'est finalement meilleur de skier dans les traces de chenilles!!<\/div><div><br><\/div><div>On trouve ensuite les quelques dizaines de mètres de moquette espérés à la montée! Quelques bons virages sereins qui font plaisir! On traverse ensuite à nouveau via la piste Corniche. Puis on retrouve Val Thorens et ses canons qui nous ont créés un tapis bien lisse! On signera ainsi les meilleurs virages de la journée 😁 juste avant de retrouver la voiture!<\/div><div>Fin de la rando et du week-end ! Malgré un ski moyen, de l'avis de tous, la journée aura été reussie... tout comme ce petit week-end en altitude!!<\/div><div>Maintenant, il faut qu'il reneige un peu... mais bon, ça reste le début de la saison malgré tout 😁<\/div><div><br><\/div>","cond":"<strong>Météo\/températures<\/strong> : Quelques nuages en début de matinée puis beau temps! Comme la veille, chaud au soleil malgré un petit air intermittent<div><br><strong>Conditions d'accès\/altitude du parking<\/strong> : <\/div><strong>Parfaites \/ 2270m<\/strong><div><strong><br><\/strong><\/div><div><strong>Altitude de chaussage\/déchaussage<\/strong><div> : 2270m \/ 2270m (encore merci aux canons!)<\/div><div><br><strong>Conditions pour le ski<\/strong> : Médiocres<\/div><div><em>Sommet et combe sous le Col de la Chambre<\/em>: bien cartonnée... difficile de savoir si on va passer au travers ou non! Attention aux cailloux sous le sommet également!<\/div><div><em>Vers le Lac de la Chambre<\/em>: la surprise du chef, quelques veines de poudre dense non ventée, entre les plaques de neige à canon<\/div><div><em>Sous le col de la Chambre jusqu'au dessus de Val Tho<\/em>: croûte infâme... pourtant avec une descente après 13h30, j'aurais pensé que ça avait suffisamment chauffé!! Mais on a quand même eu 80m de D- en moquette! 🥳<\/div><div><strong>Pistes de Val Tho<\/strong>: merci aux canons pour le tapis lisse juste revenu comme il faut... probablement la meilleure partie 😁<\/div><div><br><strong>Conditions nivo et activité avalancheuse<\/strong> : RAS<br><\/div><\/div>","skiabilite":"2","date":"1762642800","mois":"11","annee":"2025","auteur":{"id":"10956","pseudo":"Arno74"},"massif":{"id":"18","nom":"Vanoise"},"gpx":"\/sorties\/gpx\/180895.gpx","encoded":"owmsGwndg@v@Cp@_@NiAZaAFkAIkANkACmA?kA?mAEmA@kA?mAGkAOiAWeANkAPgAi@q@GkABmAWeAMiAg@s@g@u@k@k@w@Cu@Ou@Ku@Bg@t@GlA[`Ac@x@e@x@q@Vw@As@]o@e@q@a@s@_@u@Mu@Fq@b@c@z@a@|@m@h@s@Xm@j@e@t@]`A]~@[bAm@h@s@Vq@`@e@t@w@Hm@k@i@q@k@k@m@m@s@Yu@Ew@?u@Au@Gu@Zu@GWfADnAg@p@q@^[`Au@H_@_AMiAy@Bc@x@m@g@g@w@a@{@[aAa@}@a@|@KhAIlAAjAAlAClA?lAAlAWdAm@h@u@ESeAa@_AIkAYeAg@u@k@o@m@e@k@m@m@g@c@{@e@y@QgAIkACmAu@Gm@j@q@Vw@GQhAUdA\\aAj@o@?mANiATeALiACmAIkA@mAt@Xr@OFkADmABmAFkAKkAFkAe@w@WcADmAOiAGmAOiAPjADlAIlAXbAd@z@PjAOlAR