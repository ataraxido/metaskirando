:"3","date":"1761951600","mois":"11","annee":"2025","auteur":{"id":"46466","pseudo":"La Patte de Jérem"},"massif":{"id":"18","nom":"Vanoise"},"gpx":"\/sorties\/gpx\/180879.gpx","encoded":"gibsG{t_g@NhAs[_a@g@u@{a@wS[gAmCVq@d@g@x@o@b@s@Ts@\\u@b@m@j@m@f@w@Tq@j@aFt@iDyAo@q@k@u@i@y@m@i@}MmHwJoCYeAUiAYcAWkA[cAkFcQs@q@g@s@{AaAy@Oy@WyMwDyOsHm@q@]eAa@uAK_B_@qAw@s@_ABFpANlAOpAGxAIbB?tAUfAg@eB]aAw@\\i@fASpAJrABfBI~BQtA]xB{ABHvDHrAYjAc@|@WhAKlAOnApQgLtIx_@l@p@n@h@hBrCf@x@\\bARlAAlAOjAKlAYrAkEpSnFoGKpAiA~@p@|@z@`@~@b@`AZt@Xp@b@v@b@x@Rl@`A^~@FnAVxAXbA\\bAl@f@v@j@t@PTgA^iA^_BNqAD_BAoAaA}Ae@eA]qAn@{@l@y@~@_@t@eA]yA\\oBn@w@d@cAnA{Am@m@g@}@_@qBSsAQ{Aa@{@e@eB^eAh@u@~@Jb@w@f@u@j@cAd@w@j@}@|@EfAWh@vAv@]v@_@p@_@h@u@~@a@p@]p@_@dABn@aAz@q@|@ReXv@YdB\\jAl@bA|@_@~@j@r@X|BiBt@Uz@[p@{@|@Bn@e@t@s@t@g@|@k@z@SnA@lA?lAE`A?z@Iv@K|@Ov@Il@yAn@{@~@Yt@EtAFx@^dAb@|AJjADnA?|@\\bAQdE_Df@t@l@p@`Af@bCIBrFg@jA?lADrAb@_ArAoA]dA_@jANnA\\tAPtA^lA^lA\\`Ah@`AZbAj@bAn@x@b@fAl@~@l@x@l@~@j@v@l@~@fGj@~On[p@f@n@p@FwA","participants":[],"sommets":[{"id":"1304","sommet":"Cime de Caron","altitude":"3195","lat":"45.2631","lng":"6.5614"}],"depart":{"id":"994","depart":"Plan Bouchet","altitude_dep":"2355","lat":"45.2467","lng":"6.57"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180879\/ZMKqx.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180879\/4BJgw.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180879\/5nzBK.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180879\/w6pTe.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180879\/nZz8S.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180879\/Avh4d.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180879\/KZa5I.jpg"}]},{"id":"180878","titre":"poudre aux Arcs","orientation":"NW","denivele":"1300","dif_ski":"2.1","recit":"Itinéraire suivi : parking au catex avant l'épingle, lac et adret des tuffes, col de la chal, grand col, col de la chal, Aiguille Grive, plan Déchaud, parking.<br>Horaires : 9h-15h<br><div><br><\/div><div>vraiment bon, vraiment tranquille.<\/div><div>montée fabuleuse, descente sous le grand col géniale, descente de la Grive magnifique... régal intégral :)<\/div><div><br><\/div><div>... et je suis bien désolé de traiter mon courrier en retard !<\/div>","cond":"Météo\/températures : beau, froid. Des cumulus vers 2500 au sud et à l'ouest l'après midi.<br>Conditions d'accès\/altitude du parking : route blanche à partir de 1800<br>Altitude de chaussage\/déchaussage : 2000<br>Conditions pour le ski : excellentes<br><br><div>Conditions nivo et activité avalancheuse :&nbsp;<\/div><div>10 à 20cm de poudre froide sur fond dur de bas en haut, vraiment parfait.<\/div><div>on sent parfois un peu le fond sans que ce ne soit gênant.<\/div><div><br><\/div><div>Les 100m sous le col, neige un peu plus compacte travaillée par le vent, moins épais de fraiche mais pas de fond dur.<\/div>","skiabilite":"5","date":"1762124400","mois":"11","annee":"2025","auteur":{"id":"15883","pseudo":"thouthou"},"massif":{"id":"18","nom":"Vanoise"},"participants":[],"sommets":[{"id":"1914","sommet":"Aiguille Grive","altitude":"2732","lat":"45.5496","lng":"6.8041"},{"id":"4558","sommet":"Grand Col","altitude":"2935","lat":"45.5438","lng":"6.84771"}],"topos":[{"id":"8458","nom":"Aiguille Grive, Aiguille Grive par TS Arcabulle"},{"id":"8455","nom":"Grand Col, Grand col par vallon Ouest"}],"depart":{"id":"52","depart":"Les Arcs 2000","altitude_dep":"2150","lat":"45.573","lng":"6.8336"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/mGgSE.jpg","com":"altitude 2050&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/gcpkR.jpg","com":"&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/z4eNj.jpg","com":"plein soleil"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/v3Mq3.jpg","com":"Géant et Jorasses&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/LNSK3.jpg","com":"Mont Blanc&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/c90BA.jpg","com":"Aiguille de la Grive&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/z6RtP.jpg","com":"Aiguille Rouge&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/xHaPd.jpg","com":"Poilu&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/QvVoM.jpg","com":"\"au chaud\" dans le refuge du col&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/VvV1N.jpg","com":"désert blanc&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/ahH3e.jpg","com":"traces !&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/gOVIN.jpg","com":"vraiment bon&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/UuhnB.jpg","com":"les suivants ont de la place&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/ANf2B.jpg","com":"toujours la forme !&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/63fUT.jpg","com":"Pourri et glacier du Geay"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/HSi18.jpg","com":"Aiguille des Glaciers&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/udeqB.jpg","com":"Grande Casse&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/ixnLm.jpg","com":"Arc 2000&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/md9e4.jpg","com":"Descente du Grand Col&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/QDKPi.jpg","com":"Au dessus des nuages à la Grive&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/VDSRn.jpg","com":"Mont Blanc&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/bk8Ch.jpg","com":"Rouge, Grand Col, Pourri et compagnie&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/Y8QEf.jpg","com":"Les belles pentes de l'Aiguille Grive&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/oGW1g.jpg","com":"bon même sur le plat&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180878\/4OhR6.jpg","com":"un dernier mélèze pour la route&nbsp;"}]},{"id":"180877","titre":"Tricotage dans le Val Montjoie","orientation":"NW","denivele":"1850","dif_ski":"4.1","recit":"Itinéraire suivi : refuge Balme - aiguille de la Pennaz face Est - Couloir à Zub - variante en nord - remontée jusqu'à 2500m sous bellaval - lacs jovet - parking&nbsp;<br>Horaires : 9h - 17h<div><br><\/div><div>Plan D avec Étienne et Alain.<\/div><div>On devait aller vers Emosson, finalement on se rabat sur les contamines, moins loin et peut-être plus de neige.<\/div><div>Plan B Armancette, finalement c'est sec de visu donc direction la gorge (Plan C col des chasseurs).<\/div><div>Merci au gardien du refuge de la balme qui nous a monté jusqu'à son refuge en 4x4, un énorme gain de temps !!<\/div><div>Après discussion avec lui, il nous déconseille les chasseurs donc direction le secteur du Tondu (plan D).<\/div><div>Finalement on fera une première descente vers la Pennaz puis on a tricoté vers le col des tufs.<\/div><div><br><\/div><div>Assez sec dans l'ensemble... on aura pris l'air et le secteur est bien sauvage à cette période.&nbsp;<\/div><div>[youtube]VgfUNna4nt0[\/youtube]<\/div><div><br><\/div>","cond":"Météo\/températures : grand beau, peu de vent, doux.<br>Conditions d'accès\/altitude du parking : refuge de la Balme à l'aller\/ Gorge au retour<br>Altitude de chaussage\/déchaussage : 1850m<br>Conditions pour le ski :&nbsp;<div>En versant Nord, poudre reposant sur un fond dur plus ou moins présent<\/div><div>Transfo en versant ensoleillé.&nbsp;<br><br>Conditions nivo et activité avalancheuse :&nbsp;<br><\/div><div>Quelques plaques dues au transport du vent, assez visible<\/div><div>Coulées de neige lourde.<\/div>","skiabilite":"3","date":"1762297200","mois":"11","annee":"2025","auteur":{"id":"20841","pseudo":"lucasd"},"massif":{"id":"25","nom":"Mont Blanc"},"participants":[{"id":"23796","pseudo":"Etiennne"},{"id":"21459","pseudo":"alainlo"}],"sommets":[{"id":"1437","sommet":"Tête Nord des Fours","altitude":"2756","lat":"45.7355","lng":"6.726"}],"topos":[{"id":"1790","nom":"Tête Nord des Fours, Couloir à Zub"}],"depart":{"id":"295","depart":"Les Contamines (Notre Dame de la Gorge)","altitude_dep":"1200","lat":"45.796","lng":"6.71743"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180877\/FLSDC.jpg","com":"Le smile en stop"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180877\/ZKHl2.jpg","com":"Ça remue dans le stop"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180877\/WtgTk.jpg","com":"Cadavre"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180877\/PczCq.jpg","com":"Plus sec par là&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180877\/3yLID.jpg","com":"Belle neige là bas&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180877\/aKrGq.jpg","com":"Mont-Blanc de la Pennaz"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180877\/HeVMl.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180877\/V28mZ.jpg","com":"Face Est Pennaz dans le retro"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180877\/7OLhA.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180877\/XJFQ9.jpg","com":"Sommet couloir à Zub"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180877\/zpUme.jpg","com":"Vers lacs jovet"}]},{"id":"180876","titre":"Tête de Monthieu","orientation":"N","denivele":"896","dif_ski":"1.3","recit":"Itinéraire suivi : cf trace gpx<br>Horaires : Globalement 10h- 13h30","cond":"Météo\/températures : Beau et Chaud (superbe contrepèterie d'ailleurs). De plus en plus de nuages<br>Conditions d'accès\/altitude du parking : RAS<br>Altitude de chaussage\/déchaussage : 1600 à la montée, 1800 à la descente.<br>Conditions pour le ski : Étonnamment plutôt bonne ! Globalement en N, neige poudreuse qui s'allourdit au soleil, et là où le soleil ne tape pas, poudreuse encore bien légère ! Je pensais que le travail du soleil allait avoir plus d'impact. À surveiller, on est sorti le matin (entre 10h et 13h30) et les nuages avaient l'air de bien arriver sur le secteur.<br><br>Conditions nivo et activité avalancheuse :&nbsp;<br><div>Pas de trace de coulées, très rares plaques friables formées par le vent mais dans des accumulations, presque aucune ampleur c'était pas du tout inquiétant !<\/div>","skiabilite":"4","date":"1762383600","mois":"11","annee":"2025","auteur":{"id":"45404","pseudo":"Totoonio"},"massif":{"id":"24","nom":"Haut Giffre - Aiguilles Rouges"},"gpx":"\/sorties\/gpx\/180876.gpx","encoded":"oexwG}xyg@`@{@NkAd@y@t@Qt@In@e@ZeAv@Fl@f@t@Ut@Bv@Gt@Jt@Nt@Jt@El@g@^|@t@Nh@q@b@y@VfAv@AXcAZcACmA\\aAp@a@j@o@\\aAh@q@d@w@t@V\\`Ah@n@p@b@r@Pv@?t@Fn@g@l@o@ZcA`@{@b@{@f@u@^}@l@i@p@e@n@a@l@m@l@g@n@g@l@k@`@_Ah@q@^_Aj@k@n@e@r@]n@e@n@e@p@a@l@k@PkAZaA^_Ad@w@XeAZcA\\_AXeA\\aAXeA^_A`@}@b@y@n@g@h@s@l@k@j@k@j@q@v@Mt@Mr@Yt@Sr@Wt@Sn@e@n@g@VkASiA^}@n@e@n@e@t@E\\aAp@]n@g@d@y@TgAu@Su@ZRiAPiAKmA\\aAl@k@d@w@h@q@j@m@h@s@b@y@j@q@FkAVgA\\cAt@On@i@r@Ut@Pt@Lr@[t@Qt@@j@k@n@i@bAg@LkAb@y@n@d@h@p@MlAOhAKlASfAQjAKjADnAJjA?nA_@~@s@ZQhAVdAHlAHlAn@b@r@NVfAX`A?lACnAGlA?lAt@Pt@Kb@z@MjAXbAXbA`@|@u@Kg@s@j@t@d@t@@mAOiAg@{@YmAm@k@{@CWgAPqA@sA_@cAm@m@UkAo@o@w@A{@Bs@Zy@?y@SYdAw@Iq@h@u@Lw@]{@Xy@Tw@S}@@u@\\o@n@g@t@}@Ls@Zy@Y}@[u@Vq@j@WlAJlA[`Aq@n@s@Pw@\\s@X}@f@o@d@u@f@w@t@s@b@q@p@u@f@o@d@w@^c@lA[jA[rASxASfAc@hA[rA]dA_@~@[hA_@`Ak@v@q@^q@^{@Vk@p@k@r@e@bAk@n@]`Ao@p@m@|@w@Zi@l@q@d@q@d@o@d@s@d@s@p@i@n@c@|@_@~@a@x@w@?w@Hu@Au@Qq@a@q@[_@_Au@Gk@n@a@|@i@p@i@t@m@j@EnA?jAWdAq@^u@Pu@Hu@Jc@y@s@Oi@p@q@]w@@q@`@u@Dq@Xw@Iu@?u@Jm@j@q@\\m@j@c@|@m@k@u@B","participants":[],"sommets":[{"id":"635","sommet":"Tête des Lindars","altitude":"2560","lat":"45.9752","lng":"6.6982"}],"topos":[{"id":"804","nom":"Tête des Lindars, Par les pistes"}],"depart":{"id":"356","depart":"Flaine","altitude_dep":"1577","lat":"46.0048","lng":"6.6903"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180876\/DLocz.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180876\/sV78e.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180876\/YGSjT.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180876\/ix1O3.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180876\/1NWJM.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180876\/8sI2G.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180876\/ViV2Y.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180876\/ajdk8.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180876\/ME3yY.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180876\/FME3J.jpg"}]},{"id":"180875","titre":"Sortie Nivologie pentes Nord Oisans\/Laurichard","orientation":"N","denivele":"850","dif_ski":"3.2","recit":"Itinéraire suivi : Itinéraire suivi proche du topo, en contournant les roches de taille variée... <br><div>Horaires : 8h30\/14h<\/div><div><br><\/div><div>Des photos à venir !<br><\/div>","cond":"<div>Météo\/températures :&nbsp; Beau,quelques fins voiles de cirrus, léger vent de Sud. De très bonnes visibilités jusque vers la Suisse.&nbsp;<\/div><div>Air doux (+2 à +6°C)&nbsp; mais neige froide (-14°C relevés à la surface de la neige le matin puis -8°C vers midi)<\/div>Conditions d'accès\/altitude du parking : OK, parking 2050m<br>Altitude de chaussage \/déchaussage : 2050\/2200m (avec précautions)<br><div><br><\/div><div>Conditions pour le ski :&nbsp;<\/div><div>Très peu de neige dans l'ensemble sur cet itinéraire récemment exposé aux successives tempêtes océaniques... heureusement de magnifiques paysages...<br><\/div><div>Ca passe bien à la montée, avec peu de neige à brasser mais des passages \"zippants\" avec (à l'ombre)&nbsp; de la poudreuse sans cohésion en surface reposant parfois sur des surfaces dures\/regelées...<\/div><div>A la descente ski sur neige changeante.&nbsp;<\/div><div>Au dessus de 2500m neige soufflée parfois compacte ou neige plus pulvérulente dense, des roches affleurantes. Le skieur doit rester concentré...<\/div><div>Bref passage au soleil rasant, neige plus dense agréable.<\/div><div>Meilleur ski entre 2500\/2200m avec neige douce pulvérulente sur fond ferme, plus bas trop de roches affleurantes pour nos skis...<br><\/div><div><br><\/div><div>De visu davantage de neige vers les hauts glaciers de l'Oisans, l'Ouest du massif (Taillefer\/Rochail) et les faces Est des Grandes Rousses.<br><\/div><div><br><\/div><div><br><\/div><div>Conditions nivo et activité avalancheuse :&nbsp;<\/div><div>Localalement résidus de (petites) avalanches humides en Nord (boules regelees), probablement le WE passé.<\/div><div>Aperçu au loin une plus grande avalanche vers les Rousses en face Sud du col des Quirlies\/ Petit Sauvage.<\/div><div><br><\/div><div>Peu de neige, hétérogène et globalement stable avec peut-être de petites structures de plaques très localisée en faces Nord.<\/div><div>A surveiller, avec ce temps bien sec et frais à l'ombre, la neige récente de surface évolue en poudreuse sans cohésion (grains de type faces planes) : celle ci pourrait représenter une couche fragile en cas de précipitations neigeuses et\/ou de transport de neige par le vent. A surveiller notamment dans les combes\/couloirs abrités, en bas de pentes et barres rocheuses...<br><\/div><div><br><\/div><div>Sondages + tests de pelle réalisés vers 2500 et 2800m (sur épaisseur totale 60 cm environ).<\/div><div>Vers 2500m : Rien ne bouge ou juste de mini plaques de surfaces. Au soleil neige croutée.<br><\/div><div>Vers 2800m en Nord\/pente soutenue. Test compression colonne élargi : Au 2è me coup, petites rupture de 7 cm d'épais en surface (couche fragile = neige moins ventée\/ faces planes et neige roulée), sans propagation au 14ème coup rupture à 34 cm de la surface mais pas de propagation. (couche fragile = gobelets et anciens grains plus compacts\/précédemment humidifiés).<br><\/div><div>Près du sol : couche plus compacte, neige regelée\/costaude.<br><\/div><div><br><\/div><div><br><\/div><div><br><\/div><div><br><\/div>","skiabilite":"3","date":"1762297200","mois":"11","annee":"2025","auteur":{"id":"49521","pseudo":"Meteo France Grenoble"},"massif":{"id":"7","nom":"Ecrins"},"participants":[],"sommets":[{"id":"260","sommet":"Roc Noir de Combeynot","altitude":"3112","lat":"45.011","lng":"6.4003"}],"topos":[{"id":"1514","nom":"Roc Noir de Combeynot, Pente Nord du point 2861m"}],"depart":{"id":"66","depart":"Col du Lautaret","altitude_dep":"2030","lat":"45.0332","lng":"6.4037"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180875\/ey7LA.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180875\/AsTPC.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180875\/zceLa.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180875\/W5WqN.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180875\/cYah0.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180875\/VEs9q.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180875\/4MMmo.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180875\/ZMlGd.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180875\/GVzkj.jpg"}]},{"id":"180874","titre":"Grandes Platières, jamais 2 sans 3","orientation":"N","denivele":"1000","dif_ski":"1.3","recit":"Itinéraire suivi : Flaine Forêt - Grandes Platières avec un petit repeautage pour arrondir à 1000<div><br>Horaires : 8h50 - 11h10<\/div><div><br><\/div><div>Je rentre surtout la sortie pour les conditions... elles ont bien changé comme vous vous en doutez!!<\/div><div>Au début je n'avais pas forcément prévu de monter à nouveau mais message de Cyril qui me demande comment sont les conditions. Après le topo que je lui fais, il se motive. Donc par solidarité, je me sens obligé de l'accompagner 😁 Et comme on a les mêmes impératifs horaires, ça devrait bien se passer!<\/div><div><br><\/div><div>Passées les 3 zones de travaux dans la montée, on arrive enfin à Flaine Forêt... Bon, on constate que les conditions ont déjà bien changé sur le bas... c'est bien vert!!<\/div><div>Malgré tout, on arrive à chausser sur les qq cm de neige restant à l'ombre des sapins, au niveau du plat de la verte. C'est maigre, mais ça passe! Et en plus, c'est poudreux 😲 peut-être une bonne surprise en haut!<\/div><div>Sous le Blanchot, on se rend vite compte que la descente va être chaotique dans le secteur 😅 mais passé ce point critique, on retrouve tout de suite du mieux, au-dessus de 2000m. Les zones ayant pris le plus le soleil se sont parées d'une petite croûte (tout comme les nombreuses traces) mais sinon la neige reste globalement et densément poudreuse! On arrivera peut-être à faire quelque chose de bien malgré les assauts des isothermes stratosphériques des derniers jours 😁<\/div><div><br><\/div><div>Question monde, c'est loin d'être la foule! On a dû croiser en tout et pour tout 5 ou 6 skieurs... faut dire que les conditions commencent à être limites... effectivement, les traces secouent un peu, car elles ont légèrement regelé. On arrive tout de même à trouver des zones plus douces où on peut signer quelques gorilles bien méritées 😁 comme le timing est bon, on recolle pour une session, histoire d'arrondir le dénivelé!<\/div><div>Même topo pour la descente, pendant laquelle on arrive tout de même à tirer notre épingle du jeu pour faire du ski plus que correct!<\/div><div>En-dessous du bas du télésiège de Désert Blanc, comme prévu c'est un champ de mines bien sournois! On louvoie tant bien que mal pour finalement rendre les armes vers 1800m, rive gauche de la descente... ça ne valait pas le coup d'exploser un ski 😅<\/div><div>Retour à la voiture skis sur le sac... et au boulot un peu pressé par le temps, quand même 😁<\/div><div>Pour Flaine, je crois que j'attendrais la prochaine chute de neige, désormais!<br><br><\/div>","cond":"<strong>Météo\/températures<\/strong> : Grand beau, bien chaud au soleil avec néanmoins un petit vent<div><br><strong>Conditions d'accès\/altitude du parking<\/strong> : Travaux sur la route de Flaine, 3 zones à circulation alternée... ils refont le bitume! \/ 1678m<\/div><div><br><strong>Altitude de chaussage\/déchaussage<\/strong> : 1750m \/ 1800m<\/div><div><br><strong>Conditions pour le ski<\/strong> : Correctes<\/div><div><em>Sommet - bas du TSD Désert Blanc (1950m) <\/em>: 10\/20cm de poudre dense désormais bien trafolée, qq zones croûtées. Les traces peuvent secouer un peu quand on passe dessus!<\/div><div><em>1950m \/ 1800m<\/em> : ça devient le chantier... faut se faire léger et bien viser au moins jusqu'à 1850m. En dessous, c'est skiable ou non, en fonction du risque que vous voulez prendre pour vos skis 😁<\/div><div><em>En dessous de 1800m jusqu'à 1750<\/em>: il ne reste que quelques cm de neige à l'ombre des sapins, rive gauche de la piste verte... ça peut se skier mais c'est (très) joueur 😅<br><br><strong>Conditions nivo et activité avalancheuse<\/strong> : RAS<br><\/div>","skiabilite":"3","date":"1762297200","mois":"11","annee":"2025","auteur":{"id":"10956","pseudo":"Arno74"},"massif":{"id":"24","nom":"Haut Giffre - Aiguilles Rouges"},"participants":[],"sommets":[{"id":"5833","sommet":"Les Grandes Platières","altitude":"2480","lat":"45.984","lng":"6.72247"}],"topos":[{"id":"7884","nom":"Les Grandes Platières, Par les pistes"}],"depart":{"id":"787","depart":"Flaine Forêt","altitude_dep":"1678","lat":"46.0068","lng":"6.6949"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180874\/1BdUb.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180874\/L1o1d.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180874\/SlKaT.jpg"}]},{"id":"180873","titre":"Pointe de Combe Bronsin (Sud) &gt; Pte de Colomban (NE) &gt; Pte de Combe Bronsin (NE)","orientation":"NE","denivele":"1500","dif_ski":"4.2","recit":"Superbe journée d automne 🤩😎 avec tjs ces lumières particulières en cette saison. La route permet de monter assez haut et de pouvoir chausser très rapidement. Comme dans le Beaufortain, on retrouve une couche de neige tassée ce qui permet de ne pas toucher. De nombreuses possibilités. Et personne ce jour.&nbsp;","cond":"Météo\/températures : grand beau, gde douceur, chaud dans la montée de Combe Bronsin. Pas de vent.&nbsp;<br>Conditions d'accès\/altitude du parking : Route de Lachat, 1685m, l épingle qui suit est bien enneigée, ornièrée avec un peu de glace, pas tenté même avec les pneus neige, ensuite c est à nouveau goudron. 2 courts passages avec de la neige pour rejoindre le pkg à 1685m.&nbsp;<br>Altitude de chaussage\/déchaussage : 1740m juste après l épingle, dans les champs sous le refuge du Haut Gentil ( on porte 10 mn).&nbsp;<br>Conditions pour le ski :&nbsp;<div>> En montée : ça botte par endroits. Final à pied pour sortir le Pas de Freydon puis remontée également à pied par l arête pour rejoindre la Pte de Colomban &nbsp;(alternance neige dure et poudre, enfoncement limité par endroits, éventuellement crampons utiles mais ça passe sans).&nbsp;<\/div><div>Régulièrement le ski aval zippe, les couteaux peuvent être également utiles.&nbsp;<\/div><div><div>> Couloir Sud de Combe Bronsin: en transfo, lisse sur le haut, un peu de relief sur le bas. Skiabilité bonne à correcte.<\/div><div>> NE de la Pte de Colomban ( Occidental dans le topo): poudre dense, forcément plus étroit qu en plein hiver. Skiabilité bonne.&nbsp;<\/div><div>> NE de Combe Bronsin: départ sur l épaule en poudre puis rentré par une courte traversée dans le couloir. 20 à 30 cms de poudre sur fond dur. Comme pour celui de Colomban, plus étroit qu en plein hiver. Skiabilité bonne. Ensuite, la combe alterne entre poudre légère et zones légèrement croutées, skiabilité bonne à correcte.<\/div><div>> Col des Teurs: transfo. Skiabilité bonne jusqu’à la Cave même si sur le final peu de neige.<\/div><div>> de sous Lachat au départ : neige en cours de regel, du relief, ça secoue un peu. Skiabilité correcte.&nbsp;<br><div><br><br>Conditions nivo et activité avalancheuse : ras. Le couloir NE de Colomban et &nbsp;également le NE de Combe Bronsin avaient déjà purgés. Attention aux corniches pour rejoindre la Pte de Colomban par l arête.<br><\/div><\/div><\/div>","skiabilite":"3","date":"1762297200","mois":"11","annee":"2025","auteur":{"id":"1057","pseudo":"Géraud"},"massif":{"id":"19","nom":"Lauzière - Cheval Noir"},"participants":[],"sommets":[{"id":"810","sommet":"Pointe de Combe Bronsin","altitude":"2499","lat":"45.5193","lng":"6.3955"}],"topos":[{"id":"1694","nom":"Pointe de Combe Bronsin, couloirs NE en boucle"}],"depart":{"id":"520","depart":"Le Biollay","altitude_dep":"1275","lat":"45.4991","lng":"6.4317"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/4CFFa.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/T1aUt.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/ZzY5m.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/e0cMH.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/S3YE9.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/EMv66.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/sMiKP.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/zc7Tl.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/JGUA4.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/Zxf2f.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/0BWlH.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/bfS4V.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/J1kXe.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/M2ojv.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/uHTZl.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/zBd32.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/TZExw.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/UqE6G.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/fSxQe.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/nJYX7.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/NWhwd.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/lcJi2.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/eHm14.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/uruGZ.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/GLbL1.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/oKJS5.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/9whVU.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/uA53D.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/SN4rq.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/mVKDc.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/fCXOa.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/uhCRG.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/1lM95.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/hz0pW.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180873\/gdRZS.jpg"}]},{"id":"180872","titre":"Col d'Asti","orientation":"T","denivele":"750","dif_ski":"1.3","recit":"Itinéraire suivi : Brèche de Ruine, lac d'Asti et col.<br><div>Horaires : de 09:00 à 13:50<\/div><div>Avec Catherine, Nicolas et Bernard A.<\/div><div>Sortie pour voir l'enneigement sur la frontière. Très faible.<\/div><div>La sous couche dure permet de skier prudemment dans les secteurs sans chaos rocheux peu soumis au rayonnement solaire.<\/div><div>Quelques touchettes sans gravité, mais un requin planqué à 10 mètres de la voiture!<\/div><div>Pas du grand ski; mais que c'est bon d'avoir chaussé dans cette lumière automnale.<\/div><div>Une jolie trace de descente depuis Punta del Alp.<\/div>","cond":"Météo\/températures : 5° au parking à 08:45; grand bleu, sans vent<br>Conditions d'accès\/altitude du parking : barrière et B0 au Pont de Lariane; route enneigée à partir de la bergerie des Tioures; parking à 2 570 m.<br>Altitude de chaussage\/déchaussage : 2570 m<br>Conditions pour le ski : très peu de neige; skis cailloux<br><br><div>Conditions nivo et activité avalancheuse :&nbsp;<\/div><div>une dizaine de centimètres de poudre (travaillée par le vent au-dessus de 2 900 m), reposant sur 5 à 30 cm d'une couche dure souvent cassante.<\/div><div>de la face plane dans les accumulations de neige récente qui ne voient pas le soleil<\/div>","skiabilite":"2","date":"1762210800","mois":"11","annee":"2025","auteur":{"id":"2070","pseudo":"Bernard de Miscault"},"massif":{"id":"6","nom":"Queyras - Alpes Cozie N"},"participants":[],"depart":{"id":"106","depart":"Pont de Lariane (Molines En Queyras, Fontgillarde)","altitude_dep":"2020","lat":"44.7189","lng":"6.90379"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180872\/gkKOw.jpg","com":"Au col Vieux"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180872\/LQN7U.jpg","com":"Caramantran."},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180872\/OFsyy.jpg","com":"Depuis le col d'Asti: le Viso."},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180872\/ML4zk.jpg","com":"Argentera."},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180872\/nqgfm.jpg","com":"La Taillante."},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180872\/TI9BQ.jpg","com":"Grand Paradis, Mont Rose et entre les deux l silhouette du Cervin"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180872\/L0pcQ.jpg","com":"Pain de Sucre et Rocca Rossa."}]},{"id":"180871","titre":"Tempête de vent au Dôme de la Cochette","orientation":"N","denivele":"1600","dif_ski":"2.3","recit":"Itinéraire suivi : Dôme de la cochette > Aiguille de la laisse<br>Horaires : 9h30-17h<br><br><div>Une belle journée seul au monde. Que la montagne est belle :)<\/div>","cond":"Météo\/températures : Beau temps, fort vent.&nbsp;<br>Conditions d'accès\/altitude du parking : Parking 2064m, la route est fermée sans barrière coté Grenoble. Nombreuses pierre sur la route, pas de neige sur la route au retour, attention à ne pas gêner les travaux aux col.&nbsp;<br>Altitude de chaussage\/déchaussage : 2100m<br>Conditions pour le ski : Excellente poudreuse très légère sous 2500 m, non travaillée par le vent. Au-dessus, la neige est plus dense et cartonnée par endroits.<br><br>Conditions nivo et activité avalancheuse : Pas d’avalanches vues, mais beaucoup d’accumulations sur tous les versants. Nombreuses fissures dans les conversions, sans vraie propagation. On a préféré renoncer au couloir nord de l’Aiguille Noire.","skiabilite":"4","date":"1762124400","mois":"11","annee":"2025","auteur":{"id":"23796","pseudo":"Etiennne"},"massif":{"id":"13","nom":"Grandes Rousses - Arves"},"participants":[],"sommets":[{"id":"269","sommet":"Aiguille de Laisse","altitude":"2879","lat":"45.1868","lng":"6.1605"},{"id":"273","sommet":"Cimes de la Cochette","altitude":"3240","lat":"45.1682","lng":"6.1494"}],"topos":[{"id":"392","nom":"Aiguille de Laisse, versant Nord"},{"id":"1659","nom":"Cimes de la Cochette, Depuis Saint Sorlin d'Arves"}],"depart":{"id":"168","depart":"Saint Sorlin d'Arves","altitude_dep":"1648","lat":"45.2198","lng":"6.217"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/Zl420.jpg","com":"&nbsp;Héliportage"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/r1QKG.jpg","com":"&nbsp;C'est beau"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/a80Z8.jpg","com":"Dur le boulot"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/QiU8T.jpg","com":"&nbsp;Trav délicate"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/Ga6pp.jpg","com":"&nbsp;Beauuuuuu"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/Cl1Kd.jpg","com":"&nbsp;Passage à pied pour éviter les accumulations"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/HyOJk.jpg","com":"&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/Aey1e.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/khGD2.jpg","com":"Summit"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/vkLLq.jpg","com":"&nbsp;Cime de la Cochette"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/lN0p5.jpg","com":"&nbsp;Beaucoup de vent"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/gvzp3.jpg","com":"&nbsp;Gavage 5*"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/KLNlm.jpg","com":"&nbsp;Miam"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/D515h.jpg","com":"&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/FL9ez.jpg","com":"&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/wQoZq.jpg","com":"&nbsp;Bonheur"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/DD0V5.jpg","com":"&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/yEGOE.jpg","com":"&nbsp;Sommet de la l'aiguille de la Laisse"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/dWTLN.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/1cIUG.jpg","com":"&nbsp;"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180871\/qcAD1.jpg"}]},{"id":"180870","titre":"Pointe de Leisette, couloir sud","orientation":"S","denivele":"1580","dif_ski":"4.3","recit":"Itinéraire suivi : départ du cere ,route ouverte&nbsp;<br>Horaires : <br>Le couloir ne semblait pas si bien remplis de visu en montant .Au final vraimant pas pire ,on monte sur les coulées qui ont lissées la neige (crampons utiles si départ tôt )les 2 derniers tiers sont en neige plus profonde (Genoux) sur &nbsp;certains passages ,heureusement cours ,mais ça challe bien quand même. Départ tardif pour moi à 9h après le boulot ,<div>Cela aurait mérité un départ plus tôt pour skier sur une neige revenue sur fond dur .A 12h30 la neige était déjà lourde sur et sous les skis ,difficile à skier mais qu importe le flacon …pas de touchettes malgré&nbsp;<\/div><div>Quelques passages dégarnis que l on slalome ,sur le bas .<\/div><div>Le NE du roignais semblait tip top ,pas de coulées et face bien enneigée .<\/div><div>Belle sotie ,personne ce jour ..top&nbsp;<\/div>","cond":"Météo\/températures : beau chaud&nbsp;<br>Conditions d'accès\/altitude du parking : 1700 le cere&nbsp;<br>Altitude de chaussage\/déchaussage : 1700<br>Conditions pour le ski : pas si pire&nbsp;<br><br>Conditions nivo et activité avalancheuse : coulées de surfaces des dernières précipitations ,sur le bas du couloir,bon sur le haut&nbsp;","skiabilite":"3","date":"1762210800","mois":"11","annee":"2025","auteur":{"id":"42810","pseudo":"Hosanniere"},"massif":{"id":"21","nom":"Beaufortain"},"participants":[],"sommets":[{"id":"1441","sommet":"Pointe de Leisette","altitude":"2910","lat":"45.6493","lng":"6.6975"}],"topos":[{"id":"1795","nom":"Pointe de Leisette, couloir sud"}],"depart":{"id":"217","depart":"Les Echines Dessus","altitude_dep":"1320","lat":"45.6329","lng":"6.7638"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180870\/vEoM5.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180870\/zockV.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180870\/HrHed.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180870\/IbOMs.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180870\/JVWkw.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180870\/dQ7p1.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180870\/kkt6y.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180870\/qcnmr.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180870\/sibVg.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180870\/2j8qu.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180870\/HJAvu.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180870\/cYEwF.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180870\/qDZpo.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180870\/CmQJU.jpg"}]},{"id":"180869","titre":"Un Breithorn automnal bien poudreux🇮🇹","orientation":"SE","denivele":"800","dif_ski":"2.2","recit":"<strong>Itinéraire suivi :<\/strong> Montée directe à la journée depuis le plateau Rosa jusqu’au Breithorn occidental puis descente jusqu’à Plan Maison.<br><strong>Horaires :<\/strong> 11h05\/16h25.<br><div><br><\/div><div><strong>Avec :<\/strong> Jean-Marie<\/div><div><br><\/div><div>Avec cette météo exceptionnelle et la petite chute de neige d’hier dimanche c'était une période idéale pour profiter de la montagne d’autant que ce soit dans les Pyrénées comme dans les Alpes du Sud, nous attendons encore la neige afin de pour rechausser les skis 😉<br>Nous partons en peaux depuis le plateau Rosa assez tardivement car en raison du vent en début de matinée, les remontées n’ont ouvert qu’à 10h15. Du coup pas énormément de skieurs car côté Suisse, seul le téléphérique du Klein Matterhorn est ouvert. Pas mal de vent au départ mais qui va se calmer dès que l’on traversera le plateau du Breithorn. Nous progressons en ski sur les pistes en neige fraichement damée puis sur de la neige poudreuse soufflée au niveau du plateau du Breithorn. Quand la pente se redresse, le seul skieur qui nous précède monte en crampons et nous en ferons autant car la progression est plus confortable. Ascension bien agréable sans vent même si en arrivant directement depuis le niveau de la mer, l’altitude se fait bien sentir. Nous rejoignons le sommet avec ce qui est très rare, absolument personne. D’ailleurs mis à part le skieur solitaire qui nous a précédé, nous ne serons que 6 seulement au sommet ce lundi, les 3 skieurs nous suivant ayant laissé les skis avant que la pente ne se redresse. La descente depuis le sommet sera en neige légèrement soufflée sur les premiers mètres avant de trouver une bonne poudreuse. Sur le plateau du Breithorn, de la neige poudreuse parfois soufflée avant de rejoindre les pistes désertées de Zermatt\/Cervinia. Descente non-stop par les pistes en passant par le Col de Théodule pour rejoindre Plan Maison et la télécabine qui nous ramènera à Cervinia. Après cette bonne entame de saison on espère que la que la neige soit au rendez-vous 😊<br><br><\/div>","cond":"<strong>Météo\/températures :<\/strong> Très beau temps avec du vent en altitude et des températures froides mais sans excès. Fort vent juste au sommet.<br><strong>Conditions d'accès\/altitude du parking :<\/strong> RAS.<br><strong>Altitude de chaussage\/déchaussage :<\/strong> 3480m.<br><strong>Conditions pour le ski :<\/strong> Avec les chutes de neige de la veille, bonne neige poudreuse juste un peu soufflée sur le plateau du Breithorn.<br><br><strong>Conditions nivologiques et activité avalancheuse :<\/strong> RAS, bonne stabilité du manteau neigeux et crevasses bien bouchées sur l'itinéraire.","skiabilite":"4","date":"1762124400","mois":"11","annee":"2025","auteur":{"id":"2678","pseudo":"DidierGO"},"massif":{"id":"27","nom":"Valais E - Alpes Pennines E"},"participants":[],"sommets":[{"id":"577","sommet":"Breithorn","altitude":"4164","lat":"45.9408","lng":"7.74776"}],"depart":{"id":"2112","depart":"Cervinia","altitude_dep":"2000","lat":"45.9335","lng":"7.63103"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/Nq49P.jpg","com":"Panorama au téléobjectif sur le Mont-Blanc et le Grand Combin"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/qg8Dw.jpg","com":"Panorama au téléobjectif sur la Dent d'Hérens et le Cervin"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/Qfzhw.jpg","com":"Seulement précédés par un skieur sur le plateau du Breithorn"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/8UnJN.jpg","com":"Panorama sur le Breithorn à droite et le Weisshorn sur la gauche"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/aFCVX.jpg","com":"Plateau et sommet du Breithorn"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/uE49i.jpg","com":"Didier au sommet du Breithorn sur fond de Cervin"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/SGuV0.jpg","com":"Panorama depuis Castor, Pollux, Lyskamm, Gnifetti, Zumstein, Dufour et Nordent"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/3WWVh.jpg","com":"Panorama sur le Stralhorn, Rimpfischhorn et Alphubel"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/dkUJc.jpg","com":"Panorama au téléobjectif sur toutes les pointes du groupe du Monte-Rosa avec au premier plan, le Breithorn Central"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/heCkE.jpg","com":"Jean-Marie sous le sommet à l'abri du vent sur fond de Dent d'Hérens et de Cervin"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/yWhWv.jpg","com":"Panorama au téléobjectif sur le Zinalrothorn, le Schalihorn et le Weisshorn"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/Yhz0o.jpg","com":"Panorama au téléobjectif sur la Dent d'Hérens et le Cervin"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/R8BWT.jpg","com":"La descente à venir avec la trace de notre prédécesseur"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/pssIa.jpg","com":"Très bonne poudreuse"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/EiTM6.jpg","com":"Jean-Marie en cours de descente"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/zVYy9.jpg","com":"Pause sur fond de Castor avec les 3 italiens qui rejoignent leurs skis"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/cmvCS.jpg","com":"Dent d'Hérens et Cervin depuis le plateau du Cervin"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180869\/8fRsm.jpg","com":"Nos deux traces sur la gauche en bonne poudreuse"}]},{"id":"180866","titre":"Grande Sassière face Est puis Nord","orientation":"E","denivele":"2400","dif_ski":"5.3","recit":"Itinéraire suivi : Départ deux épingles au dessus du franchet, itinéraire d'été jusqu'au sommet de la grande Sassière, face Est puis Nord, montée à la Traversière en rive droite du glacier de Gliairetta, descente glacier de Rhêmes-Golette, l'interminable vallon de la Sassière, voiture&nbsp;<br>Horaires : 6h45 parking\/parking&nbsp;<div><br><\/div><div>Départ 8h30 pas bien énervé vers la grande Sassière, pas d'itinéraire en tête peut-être&nbsp; Nord\/Est on verra bien la haut...<\/div><div>Après une dizaine de manip j'arrive au sommet et la face nord\/est coté italien est bien rempli, aller on part la dessus.<\/div><div>Petit check de la face ça va faire.<\/div><div>Je suis parti à la gauche de la vierge en Est dans une pente bien raide avec des spines, petit slalom entre les barres un peu de dry ski pour finir bloquée. Je mets les crampons légère traversée pour rejoindre la neige. A partir de la le crux est passé la pente s'ouvre un peu je peux lâcher les spatules pour me faire plaisir dans une bonne poudreuse.<\/div><div>Je bifurque en face Nord au niveau du sérac et je ski la pente sous le sérac jusqu'en bas sur le glacier, rien à dire c'est top.<\/div><div>Je remonte en rive droite du glacier de Gliairetta au niveau du chemin d'été (la montée par le glacier est plus rapide mais on est en novembre et je suis seul, pas envi de tomber dans un trou)<\/div><div>Manque un peu de neige sur certaine portion encore une dizaine de manip pour arriver au sommet de la Traversière.<\/div><div>Au sommet de la Traversière je suis les cairns sur l'arête avec les skis aux pieds. Et quand tu crois que c'est fini, il y en a encore. C'est reparti pour de la désescalade...<\/div><div>Bon ski sur le glacier, un peu de recherche d'itinéraire pour pas trop abimé les skis et skating sur 5km pour quitté le vallon de la Sassière et rejoindre le parking.<\/div><div><br><\/div><div>Itinéraire un poil différent de celui décrit pour la face Est, je me suis adaptée au condition de neige dans la face<\/div><div>Le téléphone a prit froid dans la face, j'ai piqué une photo sur une autre sorti pour faire le tracé.<\/div><div>5.3 pas volé en Est&nbsp;<\/div><div><br><br><\/div>","cond":"Météo\/températures : -1 au départ\/ -5 au sommet&nbsp;<br>Conditions d'accès\/altitude du parking : parking du franchet&nbsp;<br>Altitude de chaussage\/déchaussage : 2100<br>Conditions pour le ski : face Nord et Est en bonne condi, Sud ça prend le chaud très haut<div>Avec le vent de la semaine dernière les combes sont pleines, crête et les dômes il n'y a rien<\/div><div>Sur les faces exposées Nord sous le vent (au dessus de 3000) poudreuse assez profonde 30\/40cm, sinon petit plaquage de surface en neige froide mais rien de méchant&nbsp;<span style=\"letter-spacing: 0.03em;\">&nbsp;<\/span><\/div><div><br>Conditions nivo et activité avalancheuse :&nbsp;<br><\/div><div>ça chauffe comme il faut en sud, purge naturelle<\/div><div>neige un peu plaqué sur le haut des pentes<\/div>","skiabilite":"4","date":"1762210800","mois":"11","annee":"2025","auteur":{"id":"44677","pseudo":"nilsvars"},"massif":{"id":"17","nom":"Alpes Grées N"},"gpx":"\/sorties\/gpx\/180866.gpx","encoded":"edqtG_kni@u@Po@b@g@r@i@p@o@d@g@v@k@p@k@l@k@l@m@l@m@h@q@\\k@p@i@r@_@~@g@v@m@j@s@Zs@Vq@`@u@Am@m@e@w@a@}@g@u@WiAOiAEmA?oAGmAKkAQiAWiA_@_A]cAa@{@s@Ya@}@NkAXeA^aAJmAFmAHkAf@s@EoASgAIkAUiAg@u@_@aAOkAFmASgAu@Fs@Tu@Xu@Fu@Pu@Og@w@]aAs@Wu@Mu@Bu@Nu@Lu@Hs@TIjACnAKjAAlAq@_@s@Wu@Nu@K]`Ao@d@i@p@q@b@c@{@_@~@IjA[bAYdA[`AOjAa@~@e@v@o@f@q@\\s@Zm@h@q@]u@Gc@x@e@v@q@`@u@Rq@\\s@Tq@\\m@h@q@^q@^s@Zu@@u@Lu@F]iAu@MAoAk@o@m@i@m@i@o@c@o@e@[aAr@]j@o@f@w@`@}@`@_A`@{@VeAPiAJkAu@Eu@BSgACmAUgARgAYcAa@{@ImAm@o@i@s@_@_Ag@w@g@u@g@u@c@y@[cAWeA]aAe@w@_@_AYcAOiAg@s@a@}@]aAg@s@q@a@m@i@m@m@k@m@g@s@c@y@YgAYmAYeAWgA_@aAa@{@_@_Ac@{@c@{@c@y@_@aAo@c@q@c@k@m@e@w@o@k@q@a@YgAa@{@]aAMkAMkAKkAGmAMkAKkAGmAKkAQiAImADmAEmAFmAJkAGqA?mALkALkAPiABmAJkADmAAmAAoAKkAMkAKkAAmAAmAEoAIkA[cAAmA]aAOiAGmAIkAGoACmA@mA?mAt@@t@GPiABmA?mACmAJqA\\aA@mARkADmAHmA`@{@EmAl@i@k@o@EmAi@{@s@m@AwAHwA_@aAu@Sg@s@]kAFmAt@Sv@i@CoASiAOmAWuAOiAc@cACuA^mAs@WUoAWmAKkAh@s@KsAMqASiAa@wAIaBKyAQyAOiA]kA_@oA[qA]iAa@eAa@cAa@aAe@{@g@y@q@kAe@_Am@_Aq@a@s@k@w@So@e@YeAe@w@u@Es@Uo@s@OkABuAf@w@J_B?mA?_BOaBSqAWuAa@eAWkAKwA@qAPiAAmAMmAd@y@RgAHmAb@y@`@{@b@y@VeARgATgAPkA\\aA`@}@XcATgAZaA`@_Ah@q@\\aAVeAVgALkAJkAPiARgA`@}@l@i@WeAPiAZcAb@y@`@{@`@_AXeAXcATiAPkARgAVeA^cA^_A`@{@`@{@d@w@j@o@^_Af@u@RkAJmA`@_A\\aAl@i@j@q@r@Wn@c@UgAf@s@YcAt@Dn@c@t@Gp@]b@{@n@c@r@Ur@Yp@]p@]v@Lt@Cp@`@t@Rv@Lv@Ct@Dr@\\f@u@f@s@t@Ll@i@t@Hv@It@[t@WZeA@oAJoAJkAl@i@s@YMsAHkAJ}Ah@iAd@_A`@qALkA`@}@F{AVsA\\uAVoAb@kAt@m@~@l@d@tA`@rAVzAXvAZvAd@jA^zANhAp@rAHdBNhBXhB?pBKpBDdBJfBPlALpAPpAXpAXrAJnAJjALjATjAZjAHnAJjAP|AX|ALxAHvAGvAFxAZxAf@`A`@dAb@hA^hAf@r@t@b@t@x@h@lA`@jAh@jAf@lAd@pA\\lAv@hA|@Fv@?p@f@j@bAZzAV|A@pAJjA^fA\\`AVdAXdAJrABpATfAd@|@f@x@x@?p@`@i@p@ThA`APp@\\XlA