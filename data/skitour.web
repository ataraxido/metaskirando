p\/1808\/180848\/C1IWN.jpg","com":"Il a pas perdu la main !&nbsp; "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/jJEI2.jpg","com":"Un peu de soleil "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/caLNd.jpg","com":"Nous avons retrouvé Glad' "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/WuZW6.jpg","com":"Stop à 2300m "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/oCAuv.jpg","com":"Repeautage "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/KvF0O.jpg","com":"Entre ombre et lumière "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/jvSQe.jpg","com":"Steph suit "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/hG2aP.jpg","com":"Sous Combe Neuve "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/hgRIP.jpg","com":"Au col&nbsp; "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/kFNcy.jpg","com":"Les Chapieux "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/4EQJb.jpg","com":"La Leisette "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/pTqBI.jpg","com":"Glad' s'élance&nbsp; "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/49lMI.jpg","com":"Puis Steph "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/Y7ODd.jpg","com":"On ne l'arrête plus !&nbsp; "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/3Kdpy.jpg","com":"Glad' non plus&nbsp; "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/oYVS9.jpg","com":"Il vole !&nbsp; "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/kKrUz.jpg","com":"Replat à 2300m "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/b64xT.jpg","com":"Ultime repeautage "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/Wbox3.jpg","com":"Entre les herbes "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180848\/BH97v.jpg","com":"Bon là y a plus de neige ...&nbsp; "}]},{"id":"180847","titre":"Première neige au Dôme des Petites Rousse","orientation":"S","denivele":"785","dif_ski":"1.3","recit":"Itinéraire suivi : Dôme des petites Rousses par les pistes&nbsp; <br><div>Horaires :10h\/15h30 <br><\/div><div><br><\/div><div>Bonne pioche pour démarrer la saison un 28 Octobre !<\/div><div>Soleil, neige correcte pour du bon ski, peu de monde, croisé une vingtaine de personnes. <br><\/div>","cond":"Météo\/températures : Grand beau, vent faible, chaud au soleil<br>Conditions d'accès\/altitude du parking : Route ok<br>Altitude de chaussage\/déchaussage : 2030m<br>Conditions pour le ski : poudre sur fond dur, plus conséquent à partir du lac blanc, s'alourdissant l'am sous 2400m environ, quelques requins sur le final <br><br>Conditions nivo et activité avalancheuse : Ras ce jour sur cet itinéraire ","skiabilite":"3","date":"1761606000","mois":"10","annee":"2025","auteur":{"id":"18879","pseudo":"Thierry38v"},"massif":{"id":"13","nom":"Grandes Rousses - Arves"},"participants":[{"id":"15510","pseudo":"Linaigrette"}],"sommets":[{"id":"4724","sommet":"Dôme des Petites Rousses","altitude":"2793","lat":"45.1283","lng":"6.10591"}],"depart":{"id":"1837","depart":"Alpe d'Huez Route des lacs","altitude_dep":"2040","lat":"45.1064","lng":"6.07914"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180847\/x2ieN.jpg","com":"Lac Blanc "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180847\/iREE2.jpg","com":"Lac du millieu, lac de la Fare "},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180847\/AKFoh.jpg","com":"Lac Besson, Lac Noir "}]},{"id":"180846","titre":"Couloir NE Bel Oiseau","orientation":"NE","denivele":"1350","dif_ski":"4.1","recit":"Itinéraire suivi : couloir NE en AR<br>Horaires : 9h45-15h15<div>Jolie sortie, mais la neige a souffert du redoux. Montée en AR dans le couloir (pénible, bcp d’enfoncement). Le couloir avait déjà purgé, ski assez agréable sauf le haut qui colle bien..<br><br><\/div>","cond":"Météo\/températures : doux et nuages d’altitude&nbsp;<br>Conditions d'accès\/altitude du parking :&nbsp;<br>Altitude de chaussage\/déchaussage : 1730m<br>Conditions pour le ski : correcte; neige assez humide tout de long mais pas de touchettes&nbsp;<br><br>Conditions nivo et activité avalancheuse : RAS, le manteau neigeux a l’air sain. Coupe dans le couloir n’a pas révélé de couches fragiles. Les pentes raides ont déjà purgé avec le redoux&nbsp;","skiabilite":"3","date":"1761951600","mois":"11","annee":"2025","auteur":{"id":"4544","pseudo":"gilou5"},"massif":{"id":"24","nom":"Haut Giffre - Aiguilles Rouges"},"participants":[],"sommets":[{"id":"1","sommet":"Bel Oiseau","altitude":"2628","lat":"46.0789","lng":"6.9371"}],"topos":[{"id":"910","nom":"Bel Oiseau, Couloir NE en boucle"}],"depart":{"id":"43","depart":"Finhaut","altitude_dep":"1300","lat":"46.0822","lng":"6.974"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180846\/dLvSc.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180846\/hi6KP.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180846\/dnHwl.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180846\/h2H7u.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180846\/c52Ke.jpg"}]},{"id":"180845","titre":"Combe Bénite &gt; Crêt du Rey &gt; Dzonfié","orientation":"N","denivele":"1600","dif_ski":"4.1","recit":"Il aura surtout manqué plus ( voir beaucoup plus 🥲) de luminosité, sinon au dessus de 2000m, le ski est bon et globalement très agréable. On ne touche pas. Accès haut, possibilités nombreuses, perfect 😸. Personne sur ce beau circuit, juste d anciennes traces de ski à Dzonfié.&nbsp;<div><br><\/div>","cond":"Météo\/températures : voile nuageux épais, qques gouttes le matin en montant à Combe Bénite. Un peu de vent sur les 2 premiers sommets. Visibilité très variable de bonne à médiocre.&nbsp;<br>Conditions d'accès\/altitude du parking : accès Aime. On monte sans soucis jusqu’à Véman, les dernières maisons au dessus de la Pesée.&nbsp;<br>Altitude de chaussage\/déchaussage : 1800m&nbsp;<br>Conditions pour le ski :&nbsp;<div>> Combe Bénite W: neige portante, lisse et douce. Skiabilité bonne. Visibilité correcte.&nbsp;<\/div><div>> Crêt du Rey, face Nord: poudre humide ( ça part en boulettes). Skiabilité et visibilité bonne.<\/div><div>> Descente de Pierre Percée, neige portante et douce mais visibilité médiocre.<\/div><div>> Dzonfié Est: neige portante et douce également et ce jusqu’à 1950 puis neige lourde pour finir et rejoindre la piste. Skiabilité bonne à correcte. Visibilité bonne.<\/div><div><br><br>Conditions nivo et activité avalancheuse : qques vieilles coulées parties jusqu’à l herbe et dans plusieurs orientations (W, S et E).<br><\/div>","skiabilite":"3","date":"1761951600","mois":"11","annee":"2025","auteur":{"id":"1057","pseudo":"Géraud"},"massif":{"id":"21","nom":"Beaufortain"},"participants":[],"sommets":[{"id":"802","sommet":"Crêt du Rey","altitude":"2633","lat":"45.6013","lng":"6.5991"}],"topos":[{"id":"4051","nom":"Crêt du Rey, Couloir Nord en boucle"}],"depart":{"id":"223","depart":"Arêches (Le Mappa)","altitude_dep":"1282","lat":"45.6756","lng":"6.5784"},"photos":[{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180845\/PpBcL.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180845\/amwjr.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180845\/bTiCq.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180845\/MM9Yw.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180845\/2J2R6.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180845\/ofW4n.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180845\/wL6OE.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180845\/Jd8Dg.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180845\/wgqDn.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180845\/OX9Uk.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180845\/26Pqt.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180845\/19HWN.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180845\/LtuZ6.jpg"},{"url":"https:\/\/skitour.fr\/photos_rep\/1808\/180845\/YFLUJ.jpg"},{"url":"https:\/\/skitour.fr\/pho